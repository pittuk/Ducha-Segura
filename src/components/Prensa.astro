---
import { PRENSA } from '../data/prensa';
import { asset } from '../lib/asset';
// Duplicamos la lista para que el marquee haga loop continuo (translateX -50%).
const items = [...PRENSA, ...PRENSA];
---
<section class="section section--alt" style="padding:64px 0 72px">
  <div class="container">
    <div class="section-head section-head--center reveal" style="margin-bottom:8px">
      <div class="kicker" style="margin-bottom:6px">¿Nos viste?</div>
      <h2 class="h2">Salimos en la prensa</h2>
    </div>
  </div>
  <div class="prensa-marquee reveal">
    <div class="prensa-track">
      {items.map((p, i) => (
        <a class="prensa-cell" href={p.href} aria-label={`Leer nota: ${p.name}`} aria-hidden={i >= PRENSA.length ? 'true' : undefined} tabindex={i >= PRENSA.length ? -1 : undefined}>
          <span class="prensa-cell__media">
            <img class="prensa-cell__logo" src={asset(p.logo)} alt={p.name} loading="lazy"
              onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            <span class="prensa-cell__name" style="display:none">{p.name}</span>
          </span>
          <span class="prensa-cell__tip" role="tooltip">
            <span class="prensa-cell__excerpt">{p.excerpt}</span>
            <span class="prensa-cell__cta">Leer nota completa →</span>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
/* Carrusel de prensa — marquee con tooltip por logo (pausa en hover). */
.prensa-marquee{position:relative;overflow:hidden;padding-top:108px;
  -webkit-mask-image:linear-gradient(90deg,transparent,#000 9%,#000 91%,transparent);
  mask-image:linear-gradient(90deg,transparent,#000 9%,#000 91%,transparent)}
.prensa-track{display:flex;gap:14px;width:max-content;animation:prensa-marquee 48s linear infinite}
.prensa-marquee:hover .prensa-track{animation-play-state:paused}
@keyframes prensa-marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.prensa-cell{position:relative;flex-shrink:0;width:184px;height:92px;display:flex;align-items:center;justify-content:center;background:#fff;border:1px solid var(--ds-border);border-radius:var(--ds-radius);text-decoration:none}
.prensa-cell__media{display:flex;align-items:center;justify-content:center;width:100%;height:100%;padding:18px}
.prensa-cell__logo{max-height:48px;max-width:148px;width:auto;object-fit:contain;opacity:.68;filter:grayscale(.35);transition:opacity .18s,filter .18s}
.prensa-cell__name{align-items:center;justify-content:center;text-align:center;font-family:var(--ds-display);font-weight:800;font-size:15px;color:var(--ds-blue-dark);line-height:1.15;opacity:.8;transition:opacity .18s}
.prensa-cell:hover .prensa-cell__logo,.prensa-cell:hover .prensa-cell__name{opacity:1;filter:none}
.prensa-cell__tip{position:absolute;bottom:calc(100% + 10px);left:50%;width:280px;background:var(--ds-blue-dark);color:#fff;border-radius:var(--ds-radius);padding:13px 15px;display:flex;flex-direction:column;gap:8px;z-index:20;box-shadow:0 12px 32px rgba(0,0,0,.24);opacity:0;pointer-events:none;transform:translateX(-50%) translateY(5px);transition:opacity .16s,transform .16s}
.prensa-cell__tip::after{content:'';position:absolute;top:100%;left:50%;transform:translateX(-50%);border:7px solid transparent;border-top-color:var(--ds-blue-dark)}
.prensa-cell:hover .prensa-cell__tip{opacity:1;transform:translateX(-50%) translateY(0)}
.prensa-cell__excerpt{font-size:13px;font-style:italic;line-height:1.45}
.prensa-cell__cta{font-size:12px;font-weight:700;color:#fff;opacity:.92}
@media (max-width:768px){
  .prensa-track{gap:10px}
  .prensa-cell{width:150px;height:84px}
  .prensa-marquee{padding-top:0}
  .prensa-cell__tip{display:none}
}
</style>
