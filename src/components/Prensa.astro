---
import { PRENSA } from '../data/prensa';
---
<section class="section section--alt" style="padding:64px 0">
  <div class="container">
    <div class="section-head section-head--center reveal" style="margin-bottom:32px">
      <div class="kicker">¿Nos viste? Estamos en prensa.</div>
    </div>
    <div class="prensa-grid reveal" id="prensaGrid">
      {PRENSA.map(p => (
        <div class="prensa-cell">
          <img class="prensa-cell__logo" src={p.logo} alt={p.name} loading="lazy" />
          <div class="prensa-cell__quote">{p.quote}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
/* Prensa (legacy 404–411) */
.prensa-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:1px;background:var(--ds-border);border:1px solid var(--ds-border);border-radius:var(--ds-radius);overflow:visible}
@media (max-width:768px){.prensa-grid{grid-template-columns:1fr 1fr}}
.prensa-cell{background:#fff;padding:24px 16px;min-height:90px;display:flex;align-items:center;justify-content:center;position:relative;transition:background .15s}
.prensa-cell:hover{background:#fafbfc}
.prensa-cell__logo{max-height:42px;max-width:130px;width:auto;object-fit:contain;opacity:.7;transition:opacity .15s,filter .15s;filter:grayscale(.3)}
.prensa-cell:hover .prensa-cell__logo{opacity:1;filter:none}
.prensa-cell__quote{position:absolute;bottom:calc(100% + 8px);left:50%;transform:translateX(-50%);width:220px;padding:12px 16px;background:var(--ds-blue-dark);color:#fff;border-radius:var(--ds-radius);font-size:13px;font-style:italic;line-height:1.4;text-align:center;z-index:10;box-shadow:0 8px 24px rgba(0,0,0,.2);opacity:0;pointer-events:none;transition:opacity .15s,transform .15s;transform:translateX(-50%) translateY(4px)}
.prensa-cell:hover .prensa-cell__quote{opacity:1;transform:translateX(-50%) translateY(0)}
</style>
