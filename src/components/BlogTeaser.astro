---
import { getCollection } from 'astro:content';
import BlogCard from './BlogCard.astro';
const posts = (await getCollection('blog', ({ data }) => !data.draft)).slice(0, 3);
---
<section class="section section--alt" id="blog">
  <div class="container">
    <div class="section-head section-head--row reveal">
      <div>
        <div class="kicker" style="margin-bottom:10px">Recursos para tu decisión</div>
        <h2 class="h2">Desde el blog</h2>
      </div>
      <a href="/blog" class="see-all">Todos los artículos <svg class="ic"><use href="#i-arrow"/></svg></a>
    </div>
    <div class="blog-grid reveal" id="blogGrid">
      {posts.map(post => (
        <BlogCard
          slug={post.id}
          cat={post.data.cat}
          date={post.data.date}
          title={post.data.title}
          excerpt={post.data.excerpt}
          label={post.data.label}
          bg={post.data.bg}
        />
      ))}
    </div>
  </div>
</section>
