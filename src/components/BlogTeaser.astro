---
import { BLOG_POSTS } from '../data/blogTeaser';
---
<section class="section section--alt" id="blog">
  <div class="container">
    <div class="section-head section-head--row reveal">
      <div>
        <div class="kicker" style="margin-bottom:10px">Recursos para tu decisión</div>
        <h2 class="h2">Desde el blog</h2>
      </div>
      <a href="/blog" class="see-all">Todos los artículos <svg class="ic"><use href="#i-arrow"/></svg></a>
    </div>
    <div class="blog-grid reveal" id="blogGrid">
      {BLOG_POSTS.map(p => (
        <article class="blog-card">
          <div class="blog-card__media" style={`background-color:${p.bg}`}>
            <div class="blog-card__media-l">[{p.label}]</div>
          </div>
          <div class="blog-card__body">
            <div class="blog-card__meta">
              <span>{p.cat}</span>
              <span class="dot"></span>
              <span class="date">{p.date}</span>
            </div>
            <h3 class="blog-card__title">{p.title}</h3>
            <p class="blog-card__excerpt">{p.excerpt}</p>
            <a href="/blog" class="blog-card__read">Leer artículo <svg class="ic"><use href="#i-arrow"/></svg></a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
/* Blog (legacy 436–450) */
.blog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
@media (max-width:1024px){.blog-grid{grid-template-columns:1fr 1fr}}
@media (max-width:768px){.blog-grid{grid-template-columns:1fr}}
.blog-card{background:#fff;border:1px solid var(--ds-border);border-radius:var(--ds-radius-lg);overflow:hidden;display:flex;flex-direction:column;transition:transform .2s,box-shadow .2s}
.blog-card:hover{transform:translateY(-3px);box-shadow:var(--ds-shadow)}
.blog-card__media{aspect-ratio:16/9;position:relative;background-size:14px 14px;background-image:repeating-linear-gradient(45deg,rgba(0,0,0,.035) 0 14px,transparent 14px 28px)}
.blog-card__media-l{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:ui-monospace,monospace;font-size:11px;letter-spacing:.04em;text-transform:uppercase;color:rgba(0,0,0,.5);padding:6px 12px;background:rgba(255,255,255,.78);border-radius:2px;white-space:nowrap}
.blog-card__body{padding:24px;display:flex;flex-direction:column;gap:12px;flex:1}
@media (max-width:768px){.blog-card__body{padding:20px}}
.blog-card__meta{display:flex;align-items:center;gap:10px;font-size:11px;font-weight:700;color:var(--ds-blue);letter-spacing:.06em;text-transform:uppercase}
.blog-card__meta .dot{width:3px;height:3px;border-radius:3px;background:var(--ds-border)}
.blog-card__meta .date{color:var(--ds-text)}
.blog-card__title{margin:0;font-family:var(--ds-display);font-weight:700;font-size:20px;line-height:1.2;letter-spacing:-.02em;color:var(--ds-text-strong);text-wrap:pretty}
.blog-card__excerpt{margin:0;font-size:14px;line-height:1.5;color:var(--ds-text);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.blog-card__read{margin-top:auto;font-size:14px;font-weight:600;color:var(--ds-blue);display:inline-flex;align-items:center;gap:6px;padding-top:4px}
</style>
