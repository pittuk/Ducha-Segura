---
import { SITE } from '../data/site';
import { asset } from '../lib/asset';

// Oferta del 20% en rebaje de tina (reemplaza a la antigua calculadora/configurador).
// Layout a 2 columnas: texto a la izquierda sobre la zona oscura del degradado; la foto
// (tina jacuzzi con rebaje) se ve a la derecha, donde el degradado se vuelve transparente.
const bgUrl = asset('/images/rebajes/rebaje-tina-jacuzzi-20-descuento.webp');
const waMsg = 'Hola, quiero aprovechar el 20% de descuento en el rebaje de tina. ¿Me pueden ayudar?';
const waUrl = `${SITE.whatsappUrl}?text=${encodeURIComponent(waMsg)}`;
---
<!-- ============================================================
     Oferta 20% (STAR) — bloque promocional del rebaje de tina.
     ============================================================ -->
<section class="section section--xl calc" id="calculadora">
  <div class="calc__bg" style={`background-image:url('${bgUrl}')`} aria-hidden="true"></div>
  <div class="calc__overlay" aria-hidden="true"></div>
  <div class="container">
    <div class="calc__grid">
      <div class="calc__text reveal">
        <div class="calc__promo">
          <div class="calc__promo-top">Hasta</div>
          <div class="calc__promo-num">20<span>%</span></div>
          <div class="calc__promo-txt">de descuento en tu rebaje de tina</div>
        </div>

        <p class="calc__pays">Con todo medio de pago · hasta 24 cuotas sin interés</p>
        <p class="calc__regions">
          <svg class="ic" style="width:16px;height:16px;stroke-width:2"><use href="#i-pin"/></svg>
          Servicios en RM, Valparaíso, Biobío y otras regiones
        </p>

        <div class="calc__ctas">
          <a class="btn btn--on-light btn--lg" href={waUrl} target="_blank" rel="noopener">
            <svg class="ic"><use href="#i-whatsapp"/></svg>
            <span>Quiero mi 20%</span>
          </a>
          <a class="btn btn--ghost btn--lg" href="/convenios">
            <span>Ver convenios</span>
            <svg class="ic"><use href="#i-arrow"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ==========================================================================
     Oferta 20% (rebaje de tina) — 2 columnas con foto de fondo + degradado
     ========================================================================== */
  .calc{position:relative;overflow:hidden;color:#fff;background:var(--ds-blue-dark)}
  /* Foto de fondo: encuadre a la derecha para mostrar la tina/jacuzzi y el ventanal. */
  .calc__bg{position:absolute;inset:0;background-size:cover;background-position:right bottom;z-index:0}
  /* Degradado azul oscuro (izquierda) → transparente (derecha): el texto queda sobre lo oscuro. */
  .calc__overlay{position:absolute;inset:0;z-index:1;
    background:linear-gradient(to right,
      var(--ds-blue-dark) 0%,
      rgba(1,46,77,.94) 30%,
      rgba(1,46,77,.62) 52%,
      rgba(1,46,77,.18) 72%,
      transparent 88%);}
  .calc .container{position:relative;z-index:2}

  .calc__grid{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center}
  @media (max-width:768px){.calc__grid{grid-template-columns:1fr}}
  /* En móvil la foto queda detrás de todo el bloque → reforzar el oscurecido para legibilidad. */
  @media (max-width:768px){
    .calc__overlay{background:linear-gradient(to bottom,rgba(1,46,77,.92) 0%,rgba(1,46,77,.86) 60%,rgba(1,46,77,.9) 100%)}
  }

  .calc__text{max-width:520px}

  /* Promo 20% — número GIGANTE con movimiento: destello (shine) + pulso (scale) + brillo (glow). */
  .calc__promo{text-align:left}
  .calc__promo-top{font-size:15px;font-weight:800;color:#fff;text-transform:uppercase;letter-spacing:.2em;opacity:.85}
  .calc__promo-num{
    display:inline-block;font-family:var(--ds-display);font-weight:800;
    font-size:clamp(88px,13vw,164px);line-height:.82;letter-spacing:-.05em;margin:6px 0;
    /* padding horizontal: con background-clip:text el degradado solo se pinta dentro del
       área del elemento; sin esto el glifo "%" se corta por la derecha. */
    padding:0 .16em 0 0;
    background:linear-gradient(100deg,#fff 0%,#bfe0ff 25%,#fff 50%,#bfe0ff 75%,#fff 100%);
    background-size:220% 100%;-webkit-background-clip:text;background-clip:text;
    color:transparent;-webkit-text-fill-color:transparent;
    animation:promoShine 3.4s linear infinite, promoPulse 2.8s ease-in-out infinite, promoGlow 2.8s ease-in-out infinite;
    will-change:transform,filter,background-position;
  }
  .calc__promo-num span{font-size:.46em;vertical-align:super;margin-left:3px}
  .calc__promo-txt{font-size:clamp(20px,2.6vw,26px);font-weight:700;color:#fff;max-width:340px;margin:4px 0 0;line-height:1.3}
  @keyframes promoShine{0%{background-position:220% 0}100%{background-position:-220% 0}}
  @keyframes promoPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.05)}}
  @keyframes promoGlow{0%,100%{filter:drop-shadow(0 8px 18px rgba(120,190,255,.25))}50%{filter:drop-shadow(0 10px 34px rgba(170,215,255,.6))}}
  @media (prefers-reduced-motion:reduce){.calc__promo-num{animation:none;filter:drop-shadow(0 8px 24px rgba(150,200,255,.4))}}

  .calc__pays{margin:26px 0 0;font-size:17px;font-weight:600;color:#fff}
  .calc__regions{display:inline-flex;align-items:center;gap:8px;margin:12px 0 0;font-size:15px;color:rgba(255,255,255,.85)}
  .calc__regions .ic{flex-shrink:0}

  .calc__ctas{display:flex;gap:14px;flex-wrap:wrap;margin-top:32px}
  @media (max-width:520px){.calc__ctas{width:100%;flex-direction:column}.calc__ctas .btn{width:100%}}
</style>
