---
// KitMayorista.astro — CTA de venta mayorista (compra por pallet / representación de la marca).
// Estética de franja oscura tipo pre-footer, pero con bloque CENTRADO y jerarquía tipográfica
// clara (kicker → titular grande → bajada → fila de botones).
// variant:
//   'banner'    → tarjeta contenida con bordes redondeados (catálogo, dentro de .container).
//   'prefooter' → franja full-bleed que reemplaza el CTA pre-footer (página de Kits).
import { SITE } from '../data/site';
import { asset } from '../lib/asset';
interface Props { variant?: 'banner' | 'prefooter'; bgImage?: string; }
const { variant = 'banner', bgImage } = Astro.props;
const bgUrl = bgImage ? asset(bgImage) : undefined;
const msg = 'Hola, me interesa la Opción Mayorista de Ducha Segura® (compra por pallet / representación de la marca). ¿Me pueden cotizar por volumen?';
const waUrl = `${SITE.whatsappUrl}?text=${encodeURIComponent(msg)}`;
---
<section class:list={['kitmay', `kitmay--${variant}`, { 'kitmay--hasbg': bgImage }, 'reveal']}>
  {bgUrl && <div class="kitmay__bg" style={`background-image:url('${bgUrl}')`} aria-hidden="true"></div>}
  {bgImage && <div class="kitmay__overlay" aria-hidden="true"></div>}
  <div class="kitmay__inner">
    <div class="kicker kicker--light kitmay__kicker">Opción mayorista</div>
    <h2 class="kitmay__h2">Compra por pallet y representa la marca</h2>
    <p class="kitmay__sub">Precios por volumen para distribuidores y retail. Conviértete en representante de Ducha Segura® en tu zona y vende un producto nacional patentado, con garantía de 3 años.</p>
    <div class="kitmay__ctas">
      <a href={waUrl} target="_blank" rel="noopener" class="btn btn--on-light btn--lg">
        <svg class="ic"><use href="#i-whatsapp"/></svg>
        <span>Cotizar como mayorista</span>
      </a>
      <a href="tel:+56934044939" class="btn btn--ghost btn--lg">
        <svg class="ic"><use href="#i-phone"/></svg>
        <span>Llámanos</span>
      </a>
    </div>
  </div>
</section>

<style>
  .kitmay{background:var(--ds-blue-dark);color:#fff;position:relative;overflow:hidden}
  /* Glow suave centrado-superior, como acento de luz sobre el azul sólido. */
  .kitmay::before{content:'';position:absolute;top:-40%;left:50%;transform:translateX(-50%);width:760px;height:760px;background:radial-gradient(circle,var(--ds-blue) 0%,transparent 62%);opacity:.4;filter:blur(50px);pointer-events:none}

  /* Fondo con foto + overlay azul (mismo recurso que Diferenciadores) para mantener legible el texto. */
  .kitmay__bg{position:absolute;inset:0;background-size:cover;background-position:center;z-index:0}
  .kitmay__overlay{position:absolute;inset:0;background:linear-gradient(135deg,rgba(1,46,77,.94) 0%,rgba(1,46,77,.82) 55%,rgba(0,114,192,.55) 100%);z-index:1}
  .kitmay--hasbg::before{display:none}            /* con foto, el glow sobra */
  .kitmay--hasbg .kitmay__inner{z-index:2}
  .kitmay__inner{position:relative;max-width:680px;margin:0 auto;text-align:center;display:flex;flex-direction:column;align-items:center}
  .kitmay__kicker{margin:0 0 16px}
  .kitmay__h2{margin:0;font-family:var(--ds-display);font-weight:800;line-height:1.06;letter-spacing:-.03em;color:#fff}
  .kitmay__sub{margin:20px 0 0;line-height:1.6;color:rgba(255,255,255,.78);max-width:560px}
  .kitmay__ctas{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-top:34px}
  @media (max-width:520px){.kitmay__ctas{width:100%;flex-direction:column}.kitmay__ctas .btn{width:100%}}

  /* Variante contenida (catálogo) */
  .kitmay--banner{border-radius:var(--ds-radius-lg);padding:56px 32px}
  .kitmay--banner .kitmay__h2{font-size:clamp(28px,4vw,36px)}
  .kitmay--banner .kitmay__sub{font-size:16px}

  /* Variante full-bleed (reemplaza el CTA pre-footer en Kits) */
  .kitmay--prefooter{padding:104px 24px}
  .kitmay--prefooter .kitmay__h2{font-size:clamp(34px,5vw,52px)}
  .kitmay--prefooter .kitmay__sub{font-size:18px}
  @media (max-width:768px){.kitmay--prefooter{padding:72px 20px}}
</style>
