---
import { PRODUCTS } from '../data/products';
import { ACCESORIOS } from '../data/accesorios';
import ProductCard from './ProductCard.astro';
import AccessoryCard from './AccessoryCard.astro';
// El grid destacado (.product-grid--single) está diseñado para EXACTAMENTE un producto.
// Tomamos solo el primer destacado; el resto (incl. cualquier extra) va al grid regular.
const featured = PRODUCTS.filter(p => p.featured).slice(0, 1);
const featuredIds = new Set(featured.map(p => p.id));
const regular = PRODUCTS.filter(p => !featuredIds.has(p.id));
---
<section class="section" id="productos">
  <div class="container">
    <div class="section-head section-head--row reveal">
      <div>
        <div class="kicker" style="margin-bottom:10px">Catálogo</div>
        <h2 class="h2">Elige tu rebaje. <span class="accent">Cotiza hoy.</span></h2>
      </div>
      <a href="/catalogo" class="see-all"><span>Ver todo el catálogo</span><svg class="ic"><use href="#i-arrow"/></svg></a>
    </div>

    <div class="product-grid reveal" id="productosGrid">
      {regular.map(p => <ProductCard product={p} />)}
    </div>
    <div class="product-grid product-grid--single reveal" id="productosFeatured">
      {featured.map(p => <ProductCard product={p} />)}
    </div>

    <div class="acc-head reveal">
      <h3>Accesorios — ahora se venden solos</h3>
      <a href="/accesorios" class="see-all">Ver todos <svg class="ic"><use href="#i-arrow"/></svg></a>
    </div>
    <div class="acc-grid reveal" id="accGrid">
      {ACCESORIOS.map(a => <AccessoryCard accesorio={a} />)}
    </div>
  </div>
</section>
<!-- Grillas (.product-grid/.acc-grid/.acc-head) viven ahora en base.css (utilidades compartidas). -->
