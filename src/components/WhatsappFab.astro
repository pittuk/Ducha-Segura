---
import { SITE } from '../data/site';
---
<a href={SITE.whatsappUrl + '?text=Hola%2C%20me%20gustar%C3%ADa%20consultar%20por%20un%20rebaje%20de%20tina'} target="_blank" rel="noopener" class="wa-fab" aria-label="Contactar por WhatsApp">
  <svg class="ic"><use href="#i-whatsapp"/></svg>
</a>

<style>
  .wa-fab{position:fixed;bottom:28px;right:28px;width:76px;height:76px;border-radius:50%;background:var(--ds-green-wa);color:#fff;display:flex;align-items:center;justify-content:center;box-shadow:0 8px 28px rgba(37,211,102,.55);z-index:40;transition:transform .15s}
  .wa-fab:hover{transform:scale(1.08)}
  .wa-fab .ic{width:40px;height:40px;stroke-width:2}
  @media (max-width:768px){.wa-fab{width:64px;height:64px;bottom:18px;right:18px}.wa-fab .ic{width:34px;height:34px}}
</style>
