---
// Diferenciadores.astro — "Seis razones técnicas" sobre una foto de baño con overlay
// azul. La PIEZA va al centro y alrededor 3 razones a cada lado (icono + título, sin
// descripciones).
const left = [
  { icon: 'i-factory', t: 'Producto Nacional' },
  { icon: 'i-shield',  t: 'Tecnología Antideslizante' },
  { icon: 'i-ruler',   t: 'Piezas a la Medida' },
];
const right = [
  { icon: 'i-droplet', t: 'Inclinación Antiderrame' },
  { icon: 'i-check',   t: 'Pieza Segura' },
  { icon: 'i-medal',   t: 'Garantía de 3 años' },
];
---
<section class="section section--blue diff">
  <div class="diff__bg" aria-hidden="true"></div>
  <div class="diff__overlay" aria-hidden="true"></div>
  <div class="container diff__inner">
    <div class="section-head section-head--center reveal" style="max-width:760px;margin-left:auto;margin-right:auto">
      <div class="kicker kicker--light" style="margin-bottom:10px">Por qué un Ducha Segura</div>
      <h2 class="h2">Seis razones técnicas, <span class="accent">una sola decisión.</span></h2>
    </div>

    <div class="diff-layout reveal">
      <div class="diff-col diff-col--left">
        {left.map(f => (
          <div class="diff-card">
            <span class="diff-card__ic"><svg class="ic"><use href={`#${f.icon}`}/></svg></span>
            <h3 class="diff-card__t">{f.t}</h3>
          </div>
        ))}
      </div>

      <div class="diff-media">
        <img src="/images/NUEVA_1_sinfondo-3.png" alt="Pieza de rebaje de tina Ducha Segura" width="520" height="640" loading="lazy" />
      </div>

      <div class="diff-col diff-col--right">
        {right.map(f => (
          <div class="diff-card diff-card--right">
            <span class="diff-card__ic"><svg class="ic"><use href={`#${f.icon}`}/></svg></span>
            <h3 class="diff-card__t">{f.t}</h3>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
.diff{position:relative;overflow:hidden}
/* Foto de fondo + overlay azul para mantener legible el texto blanco y resaltar la pieza */
.diff__bg{position:absolute;inset:0;background-image:url('/images/rebajes/Rebaje Tina Tradicional.webp');background-size:cover;background-position:center;z-index:0}
.diff__overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(1,46,77,.92) 0%,rgba(1,46,77,.86) 100%);z-index:1}
.diff__inner{position:relative;z-index:2}

/* Layout en 3 columnas: razones · pieza · razones */
.diff-layout{display:grid;grid-template-columns:1fr minmax(260px,460px) 1fr;align-items:center;gap:28px;margin-top:48px}
@media (max-width:980px){.diff-layout{grid-template-columns:1fr;gap:24px;margin-top:36px}}

.diff-col{display:flex;flex-direction:column;gap:16px}
@media (max-width:980px){.diff-col{gap:14px}}

.diff-media{display:flex;justify-content:center;align-items:center;order:0}
@media (max-width:980px){.diff-media{order:-1}}
.diff-media img{width:100%;max-width:420px;height:auto;display:block;filter:drop-shadow(0 30px 50px rgba(0,0,0,.35))}

.diff-card{display:flex;align-items:center;gap:14px;padding:18px 20px;border:1px solid rgba(255,255,255,.22);border-radius:14px;background:rgba(255,255,255,.07);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);transition:background .15s,border-color .15s,transform .15s}
.diff-card:hover{background:rgba(255,255,255,.13);border-color:rgba(255,255,255,.4);transform:translateY(-2px)}
/* La columna derecha refleja el contenido (icono al final) para enmarcar la pieza */
.diff-card--right{flex-direction:row-reverse;text-align:right}
@media (max-width:980px){.diff-card--right{flex-direction:row;text-align:left}}

.diff-card__ic{flex-shrink:0;width:48px;height:48px;border-radius:13px;background:rgba(255,255,255,.14);display:flex;align-items:center;justify-content:center}
.diff-card__ic .ic{width:24px;height:24px;stroke-width:2;color:#fff}

.diff-card__t{margin:0;font-family:var(--ds-display);font-weight:700;font-size:19px;line-height:1.2;letter-spacing:-.01em;color:#fff}
@media (max-width:768px){.diff-card__t{font-size:17px}}
</style>
