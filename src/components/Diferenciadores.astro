---
// Diferenciadores.astro — "Seis razones técnicas" sobre una foto de baño con overlay
// azul. La PIEZA va al centro y alrededor 3 razones a cada lado. Cada razón es un
// acordeón (<details>): al hacer clic se despliega su descripción.
import { asset } from '../lib/asset';
const bgImg = asset('/images/rebajes/Rebaje Tina Tradicional.webp');
const piezaImg = asset('/images/NUEVA_1_sinfondo-3.png');
const left = [
  { icon: 'i-factory', t: 'Producto Nacional', d: 'Pieza de fibra de vidrio reforzada de 5mm de espesor, de color blanco, creada por arquitecto y con patente de propiedad intelectual.' },
  { icon: 'i-shield',  t: 'Tecnología Antideslizante', d: 'Textura antideslizante incorporada de fábrica en su superficie, para prevenir caídas.' },
  { icon: 'i-ruler',   t: 'Piezas a la Medida', d: 'Más de 11 piezas creadas en diferentes medidas (30, 40 y 50cm de ancho), para responder a todo tipo de tinas.' },
];
const right = [
  { icon: 'i-droplet', t: 'Inclinación Antiderrame', d: 'Todas nuestras piezas cuentan con una pequeña inclinación, la cual permite el retorno del agua al interior de la tina.' },
  { icon: 'i-check',   t: 'Pieza Segura', d: 'Sus cantos y vértices son redondeados para evitar golpes o heridas.' },
  { icon: 'i-medal',   t: 'Garantía de 3 años', d: 'Garantía otorgada una vez instalada la pieza por 3 años, siguiendo las reglas de uso y mantención.' },
];
---
<section class="section section--blue diff">
  <div class="diff__bg" style={`background-image:url('${bgImg}')`} aria-hidden="true"></div>
  <div class="diff__overlay" aria-hidden="true"></div>
  <div class="container diff__inner">
    <div class="section-head section-head--center reveal" style="max-width:760px;margin-left:auto;margin-right:auto">
      <div class="kicker kicker--light" style="margin-bottom:10px">Por qué un Ducha Segura®</div>
      <h2 class="h2">Seis razones técnicas, <span class="accent">una sola decisión.</span></h2>
    </div>

    <div class="diff-layout reveal">
      <div class="diff-col diff-col--left">
        {left.map(f => (
          <details class="diff-card">
            <summary class="diff-card__head">
              <span class="diff-card__ic"><svg class="ic"><use href={`#${f.icon}`}/></svg></span>
              <h3 class="diff-card__t">{f.t}</h3>
              <svg class="ic diff-card__chevron"><use href="#i-chevron"/></svg>
            </summary>
            <p class="diff-card__desc">{f.d}</p>
          </details>
        ))}
      </div>

      <div class="diff-media">
        <img src={piezaImg} alt="Pieza de rebaje de tina Ducha Segura®" width="520" height="640" loading="lazy" />
      </div>

      <div class="diff-col diff-col--right">
        {right.map(f => (
          <details class="diff-card">
            <summary class="diff-card__head">
              <span class="diff-card__ic"><svg class="ic"><use href={`#${f.icon}`}/></svg></span>
              <h3 class="diff-card__t">{f.t}</h3>
              <svg class="ic diff-card__chevron"><use href="#i-chevron"/></svg>
            </summary>
            <p class="diff-card__desc">{f.d}</p>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
.diff{position:relative;overflow:hidden}
/* Foto de fondo + overlay azul para mantener legible el texto blanco y resaltar la pieza */
/* background-image se setea inline (asset() con ?v=hash). */
.diff__bg{position:absolute;inset:0;background-size:cover;background-position:center;z-index:0}
.diff__overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(1,46,77,.92) 0%,rgba(1,46,77,.86) 100%);z-index:1}
.diff__inner{position:relative;z-index:2}

/* Layout en 3 columnas: razones · pieza · razones */
.diff-layout{display:grid;grid-template-columns:1fr minmax(260px,460px) 1fr;align-items:center;gap:28px;margin-top:48px}
@media (max-width:980px){.diff-layout{grid-template-columns:1fr;gap:24px;margin-top:36px}}

.diff-col{display:flex;flex-direction:column;gap:16px}
@media (max-width:980px){.diff-col{gap:14px}}

.diff-media{display:flex;justify-content:center;align-items:center;order:0}
@media (max-width:980px){.diff-media{order:-1}}
.diff-media img{width:100%;max-width:420px;height:auto;display:block;filter:drop-shadow(0 30px 50px rgba(0,0,0,.35))}

/* Cada razón es un acordeón nativo (<details>). El head (summary) abre/cierra. */
.diff-card{border:1px solid rgba(255,255,255,.22);border-radius:14px;background:rgba(255,255,255,.07);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);transition:background .15s,border-color .15s}
.diff-card:hover{background:rgba(255,255,255,.13);border-color:rgba(255,255,255,.4)}
.diff-card[open]{background:rgba(255,255,255,.13);border-color:rgba(255,255,255,.4)}

.diff-card__head{display:flex;align-items:center;gap:14px;padding:18px 20px;cursor:pointer;list-style:none;user-select:none}
.diff-card__head::-webkit-details-marker{display:none}
.diff-card__head:focus-visible{outline:2px solid #fff;outline-offset:2px;border-radius:14px}

.diff-card__ic{flex-shrink:0;width:48px;height:48px;border-radius:13px;background:rgba(255,255,255,.14);display:flex;align-items:center;justify-content:center}
.diff-card__ic .ic{width:24px;height:24px;stroke-width:2;color:#fff}

.diff-card__t{flex:1;margin:0;font-family:var(--ds-display);font-weight:700;font-size:19px;line-height:1.2;letter-spacing:-.01em;color:#fff}
@media (max-width:768px){.diff-card__t{font-size:17px}}

.diff-card__chevron{flex-shrink:0;width:20px;height:20px;stroke-width:2.5;color:rgba(255,255,255,.7);transition:transform .2s}
.diff-card[open] .diff-card__chevron{transform:rotate(180deg)}

.diff-card__desc{margin:0;padding:0 20px 18px 82px;font-size:14.5px;line-height:1.55;color:rgba(255,255,255,.82)}
@media (max-width:768px){.diff-card__desc{padding-left:20px}}
</style>
