---
// ComoFunciona.astro — "¿Cómo funciona?" section (legacy markup 744–786)
---
<section class="section section--soft" id="como-funciona">
  <div class="como-wrap">
    <div class="como">
      <div class="reveal">
        <div class="kicker" style="margin-bottom:12px">El proceso</div>
        <h2 class="h2">¿Cómo lo hacemos? <span class="accent">No sacamos la tina.</span></h2>
        <p class="lead">Adaptamos tu tina existente en el lugar <strong class="lead-em">en menos de 2 horas</strong>.</p>
        <ul class="como__list">
          <li class="como__item">
            <svg class="ic como__check"><use href="#i-check"/></svg>
            <span>Realizamos un corte en la tina existente.</span>
          </li>
          <li class="como__item">
            <svg class="ic como__check"><use href="#i-check"/></svg>
            <span>Retiramos el retazo cortado e instalamos una pieza de fibra de vidrio en el borde de la tina. Fabricación 100% nacional, certificada y patentada.</span>
          </li>
          <li class="como__item">
            <svg class="ic como__check"><use href="#i-check"/></svg>
            <span>No tocamos cañerías, por ende no hay problemas de filtración.</span>
          </li>
          <li class="como__item">
            <svg class="ic como__check"><use href="#i-check"/></svg>
            <span>Retiramos los escombros o residuos de nuestro trabajo.</span>
          </li>
          <li class="como__item">
            <svg class="ic como__check"><use href="#i-check"/></svg>
            <span>Dejamos el área de trabajo limpia.</span>
          </li>
        </ul>
        <div class="como__cta">
          <a href="#calculadora" class="btn btn--primary btn--lg">
            <span>Cotizar</span>
            <svg class="ic"><use href="#i-arrow"/></svg>
          </a>
        </div>
      </div>
      <div class="video-card">
        <video class="video-card__video" id="comoVideo" preload="metadata" playsinline>
          <source src="/videos/ducha%20segura%20final.mp4" type="video/mp4" />
        </video>
        <button class="video-card__play" id="comoVideoPlay" aria-label="Reproducir video del proceso completo de rebaje de tina — Ducha Segura®"></button>
        <div class="video-card__caption">
          <div class="video-card__txt">El proceso completo — Ducha Segura®</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
/* ¿Cómo funciona? — sección a ancho completo, 30% texto / 70% video */
.como-wrap{max-width:1600px;margin:0 auto;padding:0 clamp(20px,4vw,64px)}
.como{display:grid;grid-template-columns:30% 70%;gap:56px;align-items:center}
@media (max-width:1024px){.como{grid-template-columns:1fr;gap:36px}}
.lead-em{color:var(--ds-blue);font-weight:700}
/* Viñetas sin recuadro blanco: solo check + texto, más compactas */
.como__list{list-style:none;margin:24px 0 0;padding:0;display:flex;flex-direction:column;gap:14px}
.como__item{display:flex;gap:12px;align-items:flex-start}
.como__check{width:22px;height:22px;min-width:22px;stroke-width:2.5;color:#fff;background:var(--ds-blue);border-radius:50%;padding:4px;margin-top:1px}
.como__item span{font-size:15px;line-height:1.5;color:var(--ds-text-strong)}
.como__cta{margin-top:32px}
.video-card{position:relative;aspect-ratio:16/9;width:100%;border-radius:var(--ds-radius-lg);overflow:hidden;box-shadow:var(--ds-shadow-lg);background:linear-gradient(180deg,#2a4a5e 0%,#4a6b7e 100%)}
.video-card__video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block}
.video-card__play{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:84px;height:84px;border-radius:50%;background:rgba(255,255,255,.95);display:flex;align-items:center;justify-content:center;box-shadow:0 8px 28px rgba(0,0,0,.3);transition:transform .2s,opacity .25s;cursor:pointer}
.video-card__play:hover{transform:translate(-50%,-50%) scale(1.08)}
.video-card__play::after{content:'';width:0;height:0;border-left:22px solid var(--ds-blue);border-top:14px solid transparent;border-bottom:14px solid transparent;margin-left:6px}
.video-card__caption{position:absolute;left:20px;bottom:20px;right:20px;color:#fff;pointer-events:none;text-shadow:0 1px 10px rgba(0,0,0,.65);transition:opacity .25s}
.video-card__txt{font-size:17px;font-weight:600}
.video-card.playing .video-card__play,.video-card.playing .video-card__caption{opacity:0;pointer-events:none}
</style>

<script>
  function initComoVideo(): void {
    const card = document.querySelector<HTMLElement>('.video-card');
    const video = document.getElementById('comoVideo') as HTMLVideoElement | null;
    const play = document.getElementById('comoVideoPlay');
    if (!card || !video || !play || card.dataset.bound) return;
    card.dataset.bound = '1';
    // Click en el botón central: muestra controles nativos y reproduce.
    play.addEventListener('click', () => {
      video.controls = true;
      void video.play();
    });
    // Ocultar el overlay (botón + caption) en cuanto el video arranca,
    // sin importar si se disparó desde el botón o desde los controles nativos.
    video.addEventListener('play', () => card.classList.add('playing'));
  }
  document.addEventListener('astro:page-load', initComoVideo);
</script>
