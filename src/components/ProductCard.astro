---
import type { Product } from '../data/products';
import { clp } from '../lib/format';
import { Image } from 'astro:assets';
import { PRODUCT_MEDIA } from '../data/products-media';
interface Props { product: Product; }
const { product } = Astro.props;
const media = PRODUCT_MEDIA[product.id];
---
<article class:list={['product-card', { 'product-card--featured': product.featured }]} data-product-id={product.id}>
  <div
    class:list={['product-card__media', { 'product-card__media--photo': media }]}
    style={media ? undefined : `background:linear-gradient(180deg,${product.accent}33 0%,${product.accent}cc 100%)`}
  >
    {media ? (
      <Image
        src={media.src}
        alt={media.alt}
        class:list={['product-card__img', `product-card__img--${media.fit}`]}
        widths={[400, 700, 1000]}
        sizes="(max-width:768px) 100vw, 420px"
      />
    ) : (
      <>
        <div class="product-card__media-inner"></div>
        <div class="product-card__media-label">[{product.label}]</div>
      </>
    )}
    <div class="product-card__badge"><span class={`badge badge--${product.badgeColor}`}>{product.badge}</span></div>
    <div class="product-card__chip-r">{product.medidas}</div>
  </div>
  <div class="product-card__body">
    <div>
      <h3 class="product-card__title">{product.name}</h3>
      <div class="product-card__sub">{product.sub}</div>
    </div>
    <div class="price-row">
      <span class="price-label">Desde</span>
      <span class="price-big">${clp(product.priceFrom)}</span>
    </div>
    <div class="price-cuotas">{product.cuotas}</div>
    <div class="bullets">
      {product.bullets.map(b => (
        <div class="bullet">
          <svg class="ic"><use href="#i-check"/></svg>
          <span>{b}</span>
        </div>
      ))}
    </div>
    <div class="product-card__cta">
      <button class="btn btn--primary btn--full" data-add-product={product.id}>
        <span>Personalizar y cotizar</span>
        <svg class="ic"><use href="#i-arrow"/></svg>
      </button>
    </div>
  </div>
</article>

<style>
/* Productos — product card (legacy 256–303). El grid contenedor (.product-grid*)
   vive en ProductosTeaser/catálogo, no aquí. */
.product-card{background:#fff;border:1px solid var(--ds-border);border-radius:var(--ds-radius-lg);overflow:hidden;display:flex;flex-direction:column;box-shadow:var(--ds-shadow);transition:transform .2s,box-shadow .2s}
.product-card:hover{transform:translateY(-4px);box-shadow:var(--ds-shadow-lg)}
.product-card__media{position:relative;aspect-ratio:4/3}
.product-card--featured .product-card__media{aspect-ratio:21/9}
@media (max-width:768px){.product-card--featured .product-card__media{aspect-ratio:4/3}}
.product-card__media-inner{position:absolute;inset:0;background-size:14px 14px;background-image:repeating-linear-gradient(45deg,rgba(0,0,0,.035) 0 14px,transparent 14px 28px)}
.product-card__media--photo{background:#fff}
.product-card__img{position:absolute;inset:0;width:100%;height:100%;display:block}
.product-card__img--cover{object-fit:cover}
.product-card__img--contain{object-fit:contain;padding:18px}
.product-card__media-label{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:ui-monospace,monospace;font-size:11px;letter-spacing:.04em;text-transform:uppercase;color:rgba(0,0,0,.5);padding:6px 12px;background:rgba(255,255,255,.78);border-radius:2px;white-space:nowrap}
.product-card__badge{position:absolute;top:16px;left:16px}
.product-card__chip-r{position:absolute;top:16px;right:16px;padding:4px 10px;background:rgba(255,255,255,.92);font-size:11px;font-weight:600;color:var(--ds-text-strong);border-radius:999px;letter-spacing:.04em}
.product-card__body{padding:28px;display:flex;flex-direction:column;gap:16px;flex:1}
@media (max-width:768px){.product-card__body{padding:20px}}
.product-card__title{margin:0;font-family:var(--ds-display);font-weight:700;font-size:26px;line-height:1.15;color:var(--ds-text-strong);letter-spacing:-.02em}
@media (max-width:768px){.product-card__title{font-size:22px}}
.product-card__sub{font-size:14px;color:var(--ds-text);margin-top:6px}
.price-row{display:flex;align-items:baseline;gap:8px;flex-wrap:wrap}
.price-label{font-size:12px;color:var(--ds-text);text-transform:uppercase;letter-spacing:.06em}
.price-big{font-family:var(--ds-tnum);font-weight:700;font-size:36px;color:var(--ds-text-strong);font-variant-numeric:tabular-nums;letter-spacing:-.02em;line-height:1}
@media (max-width:768px){.price-big{font-size:30px}}
.price-cuotas{font-size:13px;color:var(--ds-blue);font-weight:500}
.bullets{display:flex;flex-direction:column;gap:6px;margin-top:4px}
.bullet{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--ds-text)}
.bullet .ic{width:14px;height:14px;stroke-width:2.5;color:var(--ds-blue)}
.product-card__cta{margin-top:auto;padding-top:8px}

.badge{display:inline-flex;align-items:center;gap:4px;padding:5px 10px;border-radius:999px;font-family:var(--ds-sans);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.05em}
.badge--red{background:var(--ds-red);color:#fff}
.badge--blue{background:var(--ds-blue);color:#fff}
.badge--soft{background:var(--ds-blue-soft);color:var(--ds-blue-dark)}
</style>
