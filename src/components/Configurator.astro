---
// Configurator.astro — Visual configurator section (ported from legacy/index.html lines 815–923).
// Script logic lives in src/scripts/configurator.ts.
---
<!-- ============================================================
     Configurador visual (WOW)
     ============================================================ -->
<section class="section section--alt" id="configurador">
  <div class="container">
    <div class="cfg-head reveal">
      <div style="max-width:640px">
        <div class="kicker" style="margin-bottom:10px">Configurador visual</div>
        <h2 class="h2">Mirá cómo se va a ver<br><span class="accent">en tu baño.</span></h2>
        <p class="lead">Elegí el tipo, el ancho y el color. Después subí una foto de tu propio baño para ver el rebaje aplicado a tu tina.</p>
      </div>
      <span class="badge badge--soft">
        <svg class="ic" style="width:11px;height:11px;stroke-width:2"><use href="#i-sparkles"/></svg>
        Vista previa
      </span>
    </div>

    <div class="cfg-grid">
      <div class="cfg-preview reveal" id="cfgPreview">
        <div class="cfg-preview__label" id="cfgPreviewLabel">[BAÑO ESTÁNDAR · TINA BLANCA]</div>
        <svg class="cfg-preview__svg" viewBox="0 0 500 400" preserveAspectRatio="none">
          <g>
            <path d="M 80 200 Q 80 160 110 160 L 390 160 Q 420 160 420 200 L 420 320 Q 420 360 380 360 L 120 360 Q 80 360 80 320 Z"
                  fill="rgba(0,0,0,.35)" stroke="rgba(255,255,255,.4)" stroke-width="1.2"/>
            <path d="M 100 220 Q 100 200 130 200 L 370 200 Q 400 200 400 220 L 400 320 Q 400 340 370 340 L 130 340 Q 100 340 100 320 Z"
                  fill="rgba(0,0,0,.55)"/>
            <g id="cfgCut" style="transition:all .35s">
              <rect id="cfgCutRect" x="202.5" y="155" width="95" height="66"
                    fill="#f5f5f4" stroke="rgba(255,255,255,.85)" stroke-width="1.6"/>
              <line id="cfgCutDash" x1="202.5" y1="160" x2="297.5" y2="160"
                    stroke="rgba(255,255,255,.6)" stroke-width="1" stroke-dasharray="4 3"/>
              <g id="cfgDim">
                <line id="cfgDimLine" x1="202.5" y1="138" x2="297.5" y2="138" stroke="#fff" stroke-width="1.4"/>
                <line id="cfgDimL" x1="202.5" y1="134" x2="202.5" y2="142" stroke="#fff" stroke-width="1.4"/>
                <line id="cfgDimR" x1="297.5" y1="134" x2="297.5" y2="142" stroke="#fff" stroke-width="1.4"/>
                <text id="cfgDimT" x="250" y="128" fill="#fff" font-size="14" font-family="Inter Tight,Inter,sans-serif" font-weight="700" text-anchor="middle">40 cm</text>
              </g>
              <rect id="cfgCutGlow" x="200.5" y="153" width="99" height="70" fill="none" stroke="#0072C0" stroke-width="2.5" opacity=".85"/>
            </g>
            <g id="cfgJets" opacity="0" style="transition:opacity .25s">
              <circle cx="140" cy="290" r="4" fill="none" stroke="rgba(255,255,255,.6)" stroke-width="1.2"/>
              <circle cx="200" cy="290" r="4" fill="none" stroke="rgba(255,255,255,.6)" stroke-width="1.2"/>
              <circle cx="260" cy="290" r="4" fill="none" stroke="rgba(255,255,255,.6)" stroke-width="1.2"/>
              <circle cx="320" cy="290" r="4" fill="none" stroke="rgba(255,255,255,.6)" stroke-width="1.2"/>
              <circle cx="380" cy="290" r="4" fill="none" stroke="rgba(255,255,255,.6)" stroke-width="1.2"/>
            </g>
          </g>
        </svg>
        <div class="cfg-callout">Vista esquemática · placeholder</div>
        <button class="cfg-swap" id="cfgSwap">
          <svg class="ic" style="width:14px;height:14px;stroke-width:2"><use href="#i-swap"/></svg>
          <span>Cambiar baño de ejemplo</span>
        </button>
        <button class="cfg-upload">
          <svg class="ic" style="width:14px;height:14px;stroke-width:2"><use href="#i-user"/></svg>
          <span>Subir foto de mi baño</span>
        </button>
      </div>

      <div class="cfg-controls reveal">
        <div>
          <div class="cfg-label">Tipo de tina</div>
          <div class="cfg-opts cfg-opts--2" data-cfg="tipo">
            <button class="cfg-opt active" data-value="tradicional">
              <div class="cfg-opt__t">Tradicional</div>
              <div class="cfg-opt__s">Tina rectangular</div>
            </button>
            <button class="cfg-opt" data-value="jacuzzi">
              <div class="cfg-opt__t">Jacuzzi</div>
              <div class="cfg-opt__s">Hidromasaje</div>
            </button>
          </div>
        </div>
        <div>
          <div class="cfg-label">Ancho del rebaje</div>
          <div class="cfg-opts cfg-opts--3" data-cfg="ancho">
            <button class="cfg-opt" data-value="30">
              <div class="cfg-opt__t">30 cm</div>
              <div class="cfg-opt__s">Mínimo</div>
            </button>
            <button class="cfg-opt active" data-value="40">
              <div class="cfg-opt__t">40 cm</div>
              <div class="cfg-opt__s">Más común</div>
            </button>
            <button class="cfg-opt" data-value="50">
              <div class="cfg-opt__t">50 cm</div>
              <div class="cfg-opt__s">Máximo acceso</div>
            </button>
          </div>
        </div>
        <div>
          <div class="cfg-label">Color</div>
          <div class="cfg-colors" data-cfg="color">
            <button class="cfg-color active" data-value="blanco" data-hex="#f5f5f4" title="Blanco"><div class="cfg-color__swatch" style="background:#f5f5f4"></div><div class="cfg-color__name">Blanco</div></button>
            <button class="cfg-color" data-value="crema" data-hex="#e8dfcd" title="Crema"><div class="cfg-color__swatch" style="background:#e8dfcd"></div><div class="cfg-color__name">Crema</div></button>
            <button class="cfg-color" data-value="gris" data-hex="#b0b0ad" title="Gris"><div class="cfg-color__swatch" style="background:#b0b0ad"></div><div class="cfg-color__name">Gris</div></button>
            <button class="cfg-color" data-value="negro" data-hex="#1f1f1f" title="Negro mate"><div class="cfg-color__swatch" style="background:#1f1f1f"></div><div class="cfg-color__name">Negro mate</div></button>
          </div>
        </div>
        <div class="cfg-summary">
          <div class="cfg-summary__t">Tu configuración</div>
          <div id="cfgSummary">Rebaje <strong>Tradicional</strong> · 40 cm · color <strong>Blanco</strong></div>
        </div>
        <button class="btn btn--primary btn--full btn--lg" id="cfgAdd">
          <span>Sumar a mi cotización · $<span id="cfgPrice">229.000</span></span>
          <span class="dummy">dummy</span>
          <svg class="ic"><use href="#i-arrow"/></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  /* ==========================================================================
     Configurador — scoped styles (legacy lines 305–340, minus global classes)
     ========================================================================== */
  .cfg-head{display:flex;justify-content:space-between;align-items:flex-end;gap:16px;flex-wrap:wrap;margin-bottom:32px}
  .cfg-grid{display:grid;grid-template-columns:1.4fr 1fr;gap:24px}
  @media (max-width:1024px){.cfg-grid{grid-template-columns:1fr;gap:20px}}
  .cfg-preview{position:relative;aspect-ratio:5/4;border-radius:var(--ds-radius-lg);overflow:hidden;border:1px solid var(--ds-border);background:linear-gradient(180deg,#d6d3cf 0%,#b5b3b0 100%);background-size:14px 14px;background-image:repeating-linear-gradient(45deg,rgba(0,0,0,.05) 0 14px,transparent 14px 28px),linear-gradient(180deg,#d6d3cf 0%,#b5b3b0 100%)}
  @media (max-width:768px){.cfg-preview{aspect-ratio:4/3}}
  .cfg-preview__label{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:ui-monospace,monospace;font-size:11px;letter-spacing:.04em;text-transform:uppercase;color:rgba(0,0,0,.5);padding:6px 12px;background:rgba(255,255,255,.78);border-radius:2px;white-space:nowrap;pointer-events:none}
  .cfg-preview__svg{position:absolute;inset:0;width:100%;height:100%;pointer-events:none}
  .cfg-callout{position:absolute;top:16px;left:16px;padding:6px 12px;background:rgba(0,0,0,.5);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);color:#fff;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.06em;border-radius:999px}
  .cfg-swap{position:absolute;bottom:16px;right:16px;padding:10px 16px;background:rgba(255,255,255,.95);color:var(--ds-blue-dark);border-radius:999px;font-size:13px;font-weight:600;display:flex;align-items:center;gap:8px;box-shadow:0 4px 14px rgba(0,0,0,.18);transition:transform .12s}
  .cfg-swap:hover{transform:scale(1.03)}
  .cfg-upload{position:absolute;bottom:16px;left:16px;padding:10px 16px;background:var(--ds-blue);color:#fff;border-radius:999px;font-size:13px;font-weight:600;display:flex;align-items:center;gap:8px;box-shadow:0 4px 14px rgba(0,114,192,.4);transition:transform .12s}
  .cfg-upload:hover{transform:scale(1.03);background:var(--ds-blue-hover)}
  .cfg-controls{background:#fff;border:1px solid var(--ds-border);border-radius:var(--ds-radius-lg);padding:28px;display:flex;flex-direction:column;gap:24px}
  @media (max-width:768px){.cfg-controls{padding:20px}}
  .cfg-label{font-size:11px;font-weight:700;color:var(--ds-text);text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px}
  .cfg-opts{display:grid;gap:8px}
  .cfg-opts--2{grid-template-columns:1fr 1fr}
  .cfg-opts--3{grid-template-columns:1fr 1fr 1fr}
  .cfg-opt{padding:12px;background:#fff;border:1.5px solid var(--ds-border);border-radius:var(--ds-radius);text-align:left;transition:all .15s}
  .cfg-opt:hover{border-color:var(--ds-blue-mid)}
  .cfg-opt.active{background:var(--ds-blue-soft);border-color:var(--ds-blue)}
  .cfg-opt__t{font-size:14px;font-weight:700;color:var(--ds-text-strong);line-height:1.2}
  .cfg-opt.active .cfg-opt__t{color:var(--ds-blue)}
  .cfg-opt__s{margin-top:2px;font-size:11px;color:var(--ds-text)}
  .cfg-colors{display:flex;gap:10px;flex-wrap:wrap}
  .cfg-color{padding:0;background:transparent;text-align:center}
  .cfg-color__swatch{width:56px;height:56px;border-radius:50%;box-shadow:0 0 0 1px var(--ds-border);transition:box-shadow .15s}
  .cfg-color.active .cfg-color__swatch{box-shadow:0 0 0 2px #fff,0 0 0 4px var(--ds-blue)}
  .cfg-color__name{margin-top:6px;font-size:11px;font-weight:500;color:var(--ds-text)}
  .cfg-color.active .cfg-color__name{color:var(--ds-blue);font-weight:700}
  .cfg-summary{padding:16px;background:var(--ds-blue-soft);border-radius:var(--ds-radius);font-size:13px;line-height:1.5;color:var(--ds-text-strong)}
  .cfg-summary__t{font-weight:700;margin-bottom:4px}
</style>

<script>
  import { initConfigurator } from '../scripts/configurator';
  document.addEventListener('astro:page-load', initConfigurator);
</script>
