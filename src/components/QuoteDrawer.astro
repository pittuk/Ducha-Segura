<div class="drawer-backdrop" id="drawerBackdrop"></div>
<aside class="drawer" id="drawer" aria-label="Tu cotización" role="dialog" aria-modal="true">
  <div class="drawer__head">
    <div class="drawer__title">Tu cotización (<span id="drawerCount">0</span>)</div>
    <button class="drawer__close" id="drawerClose" aria-label="Cerrar cotización">
      <svg class="ic"><use href="#i-close"/></svg>
    </button>
  </div>
  <div class="drawer__body" id="drawerBody">
    <div class="drawer__empty" id="drawerEmpty">
      <div class="drawer__empty-icon"><svg class="ic"><use href="#i-cart"/></svg></div>
      <p style="margin:0 0 6px;font-weight:600;color:var(--ds-text-strong)">Tu cotización está vacía</p>
      <p style="margin:0;font-size:14px">Agregá productos desde el catálogo para armar tu cotización.</p>
    </div>
  </div>
  <div class="drawer__foot" id="drawerFoot" style="display:none">
    <div class="drawer__row"><span>Subtotal</span><span id="drawerSubtotal" style="font-family:var(--ds-tnum);font-variant-numeric:tabular-nums">$0</span></div>
    <div class="drawer__row"><span>Envío + instalación</span><span style="color:var(--ds-blue);font-weight:600">Incluido</span></div>
    <div class="drawer__row drawer__row--total"><span class="l">Total estimado</span><span class="v">$<span id="drawerTotal">0</span></span></div>
    <div class="drawer__note">24 cuotas sin interés disponibles al confirmar.</div>

    <a class="btn btn--primary btn--full" id="goCotizar" href="/cotizar">
      Continuar con la cotización
    </a>
    <button class="btn btn--secondary btn--full" id="goComprar" type="button" aria-disabled="true" aria-describedby="buyNote buyBlocked">
      Comprar
    </button>
    <p class="drawer__buy-note" id="buyNote" style="display:none">Pago online próximamente.</p>
    <p class="drawer__buy-note" id="buyBlocked" style="display:none">La compra online no está disponible junto a un rebaje. Continúa con la cotización.</p>
  </div>
</aside>

<!-- is:global porque los ítems del carrito y las sugerencias se inyectan por JS
     (innerHTML en scripts/cart.ts): los estilos scoped de Astro NO los alcanzan. -->
<style is:global>
  .drawer-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:200;opacity:0;pointer-events:none;transition:opacity .25s}
  .drawer-backdrop.open{opacity:1;pointer-events:auto}
  .drawer{position:fixed;top:0;right:0;bottom:0;width:460px;max-width:92vw;background:#fff;z-index:201;display:flex;flex-direction:column;box-shadow:-12px 0 40px rgba(0,0,0,.18);transform:translateX(100%);transition:transform .3s cubic-bezier(.2,.8,.2,1)}
  .drawer.open{transform:translateX(0)}
  .drawer__head{padding:20px 24px 16px;border-bottom:1px solid var(--ds-border);display:flex;align-items:center;justify-content:space-between}
  .drawer__title{font-family:var(--ds-display);font-weight:700;font-size:20px;color:var(--ds-text-strong);letter-spacing:-.02em}
  .drawer__close{width:32px;height:32px;background:var(--ds-bg-alt);color:var(--ds-text-strong);border-radius:50%;display:flex;align-items:center;justify-content:center;transition:background .15s}
  .drawer__close:hover{background:#ececec}
  .drawer__close .ic{width:16px;height:16px}
  .drawer__body{flex:1;overflow-y:auto;padding:8px 24px}
  .drawer__empty{padding:60px 20px;text-align:center;color:var(--ds-text)}
  .drawer__empty-icon{margin:0 auto 16px;width:60px;height:60px;border-radius:50%;background:var(--ds-blue-soft);display:flex;align-items:center;justify-content:center;color:var(--ds-blue)}
  .drawer__empty-icon .ic{width:28px;height:28px}
  .cart-item{padding:12px 0;border-bottom:1px solid var(--ds-border);display:flex;gap:11px}
  .cart-item__media{width:52px;height:52px;flex-shrink:0;overflow:hidden;border-radius:8px;background:#f4f4f2;position:relative}
  .cart-item__media-l{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:ui-monospace,monospace;font-size:8px;letter-spacing:.04em;color:rgba(0,0,0,.5);text-align:center;line-height:1.1;padding:0 4px}
  .cart-item__img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block}
  .cart-item__body{flex:1;min-width:0;display:flex;flex-direction:column;gap:2px}
  .cart-item__name{font-size:13px;font-weight:700;color:var(--ds-text-strong);line-height:1.25}
  .cart-item__variant{font-size:11px;color:var(--ds-text);line-height:1.3}
  .cart-item__foot{display:flex;align-items:center;justify-content:space-between;margin-top:6px}
  .qty{display:flex;align-items:center;border:1px solid var(--ds-border);border-radius:8px;overflow:hidden}
  .qty button{width:24px;height:24px;color:var(--ds-text);transition:background .12s}
  .qty button:hover{background:var(--ds-bg-alt)}
  .qty span{min-width:22px;text-align:center;font-family:var(--ds-tnum);font-size:12px;font-weight:600}
  .cart-item__price{font-family:var(--ds-tnum);font-size:14px;font-weight:700;color:var(--ds-text-strong);font-variant-numeric:tabular-nums}
  .cart-item__remove{margin-left:8px;color:var(--ds-text);opacity:.6;padding:4px;transition:opacity .15s,color .15s}
  .cart-item__remove:hover{opacity:1;color:var(--ds-red)}
  .cart-item__remove .ic{width:14px;height:14px}
  /* "Complementa tu rebaje" — accesorios agregables desde el carrito */
  .cart-suggest{margin-top:14px;padding-top:14px;border-top:1px solid var(--ds-border)}
  .cart-suggest__h{font-size:12px;font-weight:700;color:var(--ds-text-strong);margin-bottom:8px}
  .cart-suggest__row{display:flex;gap:8px;overflow-x:auto;padding-bottom:6px;scroll-snap-type:x mandatory;scrollbar-width:thin}
  .cart-suggest__card{flex:0 0 88px;scroll-snap-align:start;display:flex;flex-direction:column;gap:3px;border:1px solid var(--ds-border);border-radius:10px;padding:6px}
  .cart-suggest__media{height:42px;border-radius:6px;overflow:hidden;background:#fff;display:flex;align-items:center;justify-content:center}
  .cart-suggest__media img{width:100%;height:100%;object-fit:contain;display:block}
  .cart-suggest__name{font-size:10px;font-weight:600;color:var(--ds-text-strong);line-height:1.2;min-height:24px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
  .cart-suggest__price{font-size:11px;font-weight:700;color:var(--ds-text-strong);font-family:var(--ds-tnum);font-variant-numeric:tabular-nums}
  .cart-suggest__add{margin-top:1px;padding:5px 6px;background:var(--ds-blue-soft);color:var(--ds-blue-dark);border-radius:7px;font-size:10px;font-weight:700;transition:background .15s,color .15s}
  .cart-suggest__add:hover{background:var(--ds-blue);color:#fff}
  .drawer__foot{padding:14px 24px 16px;border-top:1px solid var(--ds-border);background:var(--ds-bg-alt)}
  .drawer__row{display:flex;justify-content:space-between;font-size:13px;color:var(--ds-text);margin-bottom:6px}
  .drawer__row--total{align-items:baseline;margin-top:6px;margin-bottom:10px}
  .drawer__row--total .l{font-size:14px;font-weight:700;color:var(--ds-text-strong)}
  .drawer__row--total .v{font-family:var(--ds-tnum);font-size:26px;font-weight:700;color:var(--ds-text-strong);font-variant-numeric:tabular-nums;letter-spacing:-.02em}
  .drawer__note{font-size:12px;color:var(--ds-text);margin-bottom:10px;text-align:center}
  .drawer__buy-note{font-size:12px;color:var(--ds-text);margin:8px 0 0;text-align:center}
  #goComprar{margin-top:8px}
  #goComprar[aria-disabled="true"]{opacity:.5;cursor:not-allowed}
  #goComprar[aria-disabled="true"]:hover{background:#fff;transform:none}
</style>
