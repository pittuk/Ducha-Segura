---
// Header.astro — Cabecera del sitio + mobile menu drawer (legacy 636–672 + 1241–1265).
// CSS de componente = legacy "Header" CSS (76–120) y "Mobile menu drawer" (554–566),
// sin clases globales duplicadas.
import { Image } from 'astro:assets';
import logoAzul from '../assets/logo-azul.png';
import { NAV } from '../data/site';
const path = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? path === '/' : (path === href || path.startsWith(href + '/'));
---
<header class="header">
  <a href="/" class="logo" aria-label="Ducha Segura — Inicio">
    <Image class="logo__circle" src={logoAzul} alt="" width={85} height={85} densities={[2]} />
  </a>

  <nav class="nav" aria-label="Navegación principal">
    {NAV.map(item => {
      const itemActive = isActive(item.href) || (item.children?.some(c => isActive(c.href)) ?? false);
      return item.children ? (
        <div class="nav__item">
          <a href={item.href} class:list={["nav__link", { active: itemActive }]} aria-haspopup="true">
            {item.label}<span class="nav__caret" aria-hidden="true">▾</span>
          </a>
          <div class="nav__dropdown" role="menu">
            {item.children.map(c => (
              <a href={c.href} class:list={["nav__dropdown-link", { active: isActive(c.href) }]} role="menuitem">{c.label}</a>
            ))}
          </div>
        </div>
      ) : (
        <a href={item.href} class:list={["nav__link", { active: itemActive }]}>{item.label}</a>
      );
    })}
  </nav>

  <div class="header__actions">
    <button class="icon-btn hide-mobile" id="searchTrigger" aria-label="Buscar productos" aria-expanded="false" aria-controls="searchOverlay">
      <svg class="ic" style="width:20px;height:20px"><use href="#i-search"/></svg>
    </button>
    <button class="cart-trigger" id="cartTrigger" aria-label="Ver mi cotización" aria-expanded="false" aria-controls="drawer">
      <svg class="ic"><use href="#i-cart"/></svg>
      <span class="cart-trigger__label">Cotización</span>
      <span class="cart-badge" id="cartBadge">0</span>
    </button>
    <button class="menu-btn" id="menuBtn" aria-label="Abrir menú" aria-expanded="false" aria-controls="menuDrawer">
      <svg class="ic" style="width:22px;height:22px"><use href="#i-menu"/></svg>
    </button>
  </div>
</header>

<!-- Mobile menu drawer (legacy 1240–1265) -->
<div class="menu-backdrop" id="menuBackdrop"></div>
<aside class="menu-drawer" id="menuDrawer" aria-label="Menú principal">
  <div class="menu-drawer__head">
    <div class="logo">
      <Image class="logo__circle" src={logoAzul} alt="" width={85} height={85} densities={[2]} />
      <div class="logo__txt">
        <span class="logo__name">Ducha Segura<sup>®</sup></span>
        <span class="logo__sub">CHILE</span>
      </div>
    </div>
    <button class="drawer__close" id="menuClose" aria-label="Cerrar menú">
      <svg class="ic"><use href="#i-close"/></svg>
    </button>
  </div>
  <nav class="menu-drawer__nav">
    {NAV.map(item => (
      <>
        <a href={item.href} class:list={[{ active: isActive(item.href) }]}>{item.label}</a>
        {item.children?.map(c => (
          <a href={c.href} class:list={["menu-drawer__sub", { active: isActive(c.href) }]}>{c.label}</a>
        ))}
      </>
    ))}
  </nav>
</aside>

<!-- Search overlay -->
<div class="search-overlay" id="searchOverlay" role="dialog" aria-modal="true" aria-label="Buscar productos">
  <div class="search-panel">
    <div class="search-box">
      <svg class="ic search-box__ic"><use href="#i-search"/></svg>
      <input type="search" id="searchInput" class="search-box__input" placeholder="Busca un rebaje, kit o accesorio…" autocomplete="off" aria-label="Buscar productos" />
      <button class="search-box__close" id="searchClose" aria-label="Cerrar buscador">
        <svg class="ic"><use href="#i-close"/></svg>
      </button>
    </div>
    <div class="search-results" id="searchResults" role="listbox" aria-label="Resultados"></div>
  </div>
</div>

<style>
/* Header (legacy 79–120) */
.header{height:85px;background:rgba(255,255,255,.94);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-bottom:1px solid var(--ds-border);position:sticky;top:0;z-index:50;display:flex;align-items:center;padding:0 48px}
@media (max-width:768px){.header{height:92px;padding:0 16px}}
.logo{display:flex;align-items:center;gap:10px;color:var(--ds-text-strong)}
.logo__circle{width:85px;height:85px;border-radius:50%;background:var(--ds-blue);display:flex;align-items:center;justify-content:center;color:#fff;font-family:var(--ds-display);font-weight:800;font-size:30px;letter-spacing:-.04em;flex-shrink:0}
img.logo__circle{background:#fff;object-fit:contain}
.logo__txt{display:flex;flex-direction:column;line-height:1}
.logo__name{font-family:var(--ds-display);font-weight:800;font-size:18px;letter-spacing:-.02em}
@media (max-width:768px){.logo__name{font-size:14px}}
.logo__name sup{font-size:.55em;vertical-align:super;margin-left:1px}
.logo__sub{font-family:var(--ds-sans);font-size:10px;font-weight:500;color:var(--ds-text);letter-spacing:.04em;text-transform:uppercase;margin-top:2px}
@media (max-width:768px){.logo__sub{font-size:9px}}

.nav{display:flex;gap:28px;margin-left:56px;flex:1}
@media (max-width:1024px){.nav{display:none}}
.nav__link{color:var(--ds-text-strong);font-size:15px;font-weight:500;padding:8px 0;position:relative;transition:color .15s}
.nav__link:hover{color:var(--ds-blue)}
.nav__link.active{color:var(--ds-blue);font-weight:600}
.nav__link.active::after{content:'';position:absolute;left:0;right:0;bottom:0;height:2px;background:var(--ds-blue);border-radius:1px}

/* Dropdown (desktop) — hover/focus, sin JS */
.nav__item{position:relative;display:flex;align-items:center}
.nav__caret{font-size:10px;margin-left:5px;display:inline-block;transition:transform .15s}
.nav__item:hover .nav__caret,.nav__item:focus-within .nav__caret{transform:rotate(180deg)}
.nav__dropdown{position:absolute;top:100%;left:0;min-width:180px;background:#fff;border:1px solid var(--ds-border);border-radius:var(--ds-radius);box-shadow:var(--ds-shadow-lg);padding:6px;display:flex;flex-direction:column;gap:2px;opacity:0;visibility:hidden;transform:translateY(6px);transition:opacity .15s,transform .15s;z-index:60}
.nav__item:hover .nav__dropdown,.nav__item:focus-within .nav__dropdown{opacity:1;visibility:visible;transform:translateY(0)}
.nav__dropdown-link{padding:9px 12px;border-radius:8px;font-size:14px;font-weight:500;color:var(--ds-text-strong);white-space:nowrap;transition:background .15s,color .15s}
.nav__dropdown-link:hover{background:var(--ds-bg-alt);color:var(--ds-blue)}
.nav__dropdown-link.active{color:var(--ds-blue)}

.header__actions{display:flex;align-items:center;gap:10px;margin-left:auto}
@media (max-width:1024px){.header__actions{gap:6px}}

.icon-btn{color:var(--ds-text-strong);padding:10px;display:flex;border-radius:999px;transition:background .15s}
.icon-btn:hover{background:var(--ds-bg-alt)}
@media (max-width:1024px){.icon-btn.hide-mobile{display:none}}

.cart-trigger{position:relative;background:var(--ds-bg-alt);color:var(--ds-text-strong);padding:10px 14px;border-radius:999px;display:flex;align-items:center;gap:8px;font-size:14px;font-weight:600;transition:background .15s}
.cart-trigger:hover{background:#ececec}
.cart-trigger__label{display:inline}
@media (max-width:1024px){.cart-trigger{padding:8px;border-radius:50%}.cart-trigger__label{display:none}}
.cart-badge{background:var(--ds-red);color:#fff;font-size:11px;font-weight:700;min-width:18px;height:18px;border-radius:9px;display:flex;align-items:center;justify-content:center;padding:0 5px}
@media (max-width:1024px){.cart-badge{position:absolute;top:0;right:0;font-size:10px;min-width:16px;height:16px}}

.menu-btn{display:none;color:var(--ds-text-strong);padding:8px}
@media (max-width:1024px){.menu-btn{display:flex}}

/* Mobile menu drawer (legacy 554–566) */
.menu-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:200;opacity:0;pointer-events:none;transition:opacity .25s}
.menu-backdrop.open{opacity:1;pointer-events:auto}
.menu-drawer{position:fixed;top:0;right:0;bottom:0;width:300px;max-width:88vw;background:#fff;z-index:201;display:flex;flex-direction:column;box-shadow:-12px 0 40px rgba(0,0,0,.18);transform:translateX(100%);transition:transform .3s cubic-bezier(.2,.8,.2,1)}
.menu-drawer.open{transform:translateX(0)}
.menu-drawer__head{padding:18px 20px;border-bottom:1px solid var(--ds-border);display:flex;align-items:center;justify-content:space-between}
.menu-drawer__nav{padding:8px 0;display:flex;flex-direction:column}
.menu-drawer__nav a{padding:14px 24px;font-size:16px;font-weight:600;color:var(--ds-text-strong)}
.menu-drawer__nav a:hover{background:var(--ds-bg-alt);color:var(--ds-blue)}
.menu-drawer__nav a.active{color:var(--ds-blue);background:var(--ds-bg-alt)}
.menu-drawer__nav a.menu-drawer__sub{padding-left:42px;font-size:15px;font-weight:500;color:var(--ds-text)}
.menu-drawer__nav a.menu-drawer__sub::before{content:'└';margin-right:8px;color:var(--ds-text-soft, #9aa)}

/* drawer__close is also used in the mobile header */
.drawer__close{width:32px;height:32px;background:var(--ds-bg-alt);color:var(--ds-text-strong);border-radius:50%;display:flex;align-items:center;justify-content:center;transition:background .15s}
.drawer__close:hover{background:#ececec}
.drawer__close .ic{width:16px;height:16px}

.cfg-label{font-size:12px;font-weight:700;color:var(--ds-text-strong);text-transform:uppercase;letter-spacing:.06em}

/* Search overlay */
.search-overlay{position:fixed;inset:0;z-index:210;background:rgba(1,46,77,.45);backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px);opacity:0;visibility:hidden;transition:opacity .2s,visibility .2s}
.search-overlay.open{opacity:1;visibility:visible}
.search-panel{position:absolute;top:0;left:0;right:0;background:#fff;box-shadow:var(--ds-shadow-lg);padding:20px 48px 24px;transform:translateY(-12px);transition:transform .22s cubic-bezier(.2,.8,.2,1);max-height:88vh;display:flex;flex-direction:column}
.search-overlay.open .search-panel{transform:translateY(0)}
@media (max-width:768px){.search-panel{padding:16px 16px 20px}}
.search-box{display:flex;align-items:center;gap:12px;border:1px solid var(--ds-border);border-radius:999px;padding:10px 16px;background:var(--ds-bg-alt)}
.search-box:focus-within{border-color:var(--ds-blue);background:#fff}
.search-box__ic{width:20px;height:20px;color:var(--ds-text);flex-shrink:0}
.search-box__input{flex:1;border:none;background:transparent;font-family:var(--ds-sans);font-size:17px;color:var(--ds-text-strong);outline:none}
.search-box__input::placeholder{color:var(--ds-text-soft,#9aa)}
.search-box__close{flex-shrink:0;color:var(--ds-text-strong);padding:6px;display:flex;border-radius:50%;transition:background .15s}
.search-box__close:hover{background:#ececec}
.search-box__close .ic{width:18px;height:18px}
.search-results{margin-top:14px;overflow-y:auto;display:flex;flex-direction:column;gap:4px}
.search-result{display:flex;align-items:center;gap:14px;padding:10px 12px;border-radius:12px;color:var(--ds-text-strong);transition:background .15s}
.search-result:hover,.search-result.active{background:var(--ds-bg-alt)}
.search-result__img{width:52px;height:52px;border-radius:10px;object-fit:cover;background:var(--ds-bg-alt);flex-shrink:0}
.search-result__body{display:flex;flex-direction:column;gap:2px;min-width:0}
.search-result__name{font-size:15px;font-weight:600;line-height:1.25}
.search-result__desc{font-size:13px;color:var(--ds-text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.search-result__price{margin-left:auto;font-size:14px;font-weight:700;color:var(--ds-blue);white-space:nowrap;flex-shrink:0}
.search-empty{padding:20px 12px;color:var(--ds-text);font-size:15px}
.search-empty b{color:var(--ds-text-strong)}
</style>
