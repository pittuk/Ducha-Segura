---
import { CONVENIOS } from '../data/convenios';
const items = [...CONVENIOS, ...CONVENIOS];
---
<section class="convenios" aria-label="Convenios vigentes">
  <div class="convenios__head">
    <div class="kicker">Nuestros convenios vigentes</div>
  </div>
  <div class="marquee">
    <div class="marquee__track" id="conveniosTrack">
      {items.map(c => (
        <div class="convenio-chip"><img src={c.logo} alt={c.name} loading="lazy" /></div>
      ))}
    </div>
  </div>
</section>

<style>
/* Convenios strip (legacy 190–199) */
.convenios{background:var(--ds-bg);border-top:1px solid var(--ds-border);border-bottom:1px solid var(--ds-border);padding:40px 0;overflow:hidden}
@media (max-width:768px){.convenios{padding:32px 0}}
.convenios__head{text-align:center;margin-bottom:20px;padding:0 20px}
.marquee{position:relative;mask-image:linear-gradient(90deg,transparent,#000 12%,#000 88%,transparent);-webkit-mask-image:linear-gradient(90deg,transparent,#000 12%,#000 88%,transparent)}
.marquee__track{display:flex;gap:56px;animation:marquee 35s linear infinite;width:max-content}
@media (max-width:768px){.marquee__track{gap:32px}}
@keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.convenio-chip{display:flex;align-items:center;justify-content:center;height:64px;flex-shrink:0;opacity:.75;transition:opacity .2s}
.convenio-chip img{max-height:56px;max-width:170px;width:auto;object-fit:contain}
.convenio-chip:hover{opacity:1}
@media (max-width:768px){.convenio-chip img{max-height:44px;max-width:130px}}
</style>
