---
import { HERO_COPY } from '../data/hero';
import { SITE } from '../data/site';
const h = HERO_COPY.user;
---
<section class="hero" aria-label="Presentación principal">
  <div class="slider" id="slider" role="region" aria-label="Comparador antes y después">
    <div class="slider__layer slider__after" aria-hidden="true">
      <div class="slider__label slider__label--after">Después</div>
    </div>
    <div class="slider__layer slider__before" id="sliderBefore" style="clip-path:polygon(0 0,50% 0,50% 100%,0 100%);-webkit-clip-path:polygon(0 0,50% 0,50% 100%,0 100%)" aria-hidden="true"></div>
    <div class="slider__handle" id="sliderHandle" style="left:50%"></div>
    <div class="slider__knob" id="sliderKnob" style="left:50%">
      <svg class="ic" style="width:20px;height:20px;stroke-width:2"><use href="#i-swap"/></svg>
    </div>
  </div>

  <div class="hero__overlay" aria-hidden="true"></div>

  <div class="slider__hint">
    <svg class="ic" style="width:13px;height:13px;stroke-width:2"><use href="#i-swap"/></svg>
    <span>Desliza la flecha para ver el cambio</span>
  </div>

  <div class="hero__content">
    <div class="hero__inner">
      <h1 class="h1">
        <span id="heroH1A">{h.h1A}</span>
        <span id="heroH1B">{h.h1B}</span>
      </h1>
      <p class="hero__sub" id="heroSub">{h.sub}</p>
      <div class="hero__ctas">
        <a href="#productos" class="btn btn--on-light btn--lg" id="heroCtaPrimary">
          <span>{h.primary}</span>
          <svg class="ic"><use href="#i-arrow"/></svg>
        </a>
        <a href={SITE.whatsappUrl} target="_blank" rel="noopener" class="btn btn--ghost btn--lg" id="heroCtaSecondary">
          <svg class="ic"><use href="#i-whatsapp"/></svg>
          <span>{h.secondary}</span>
        </a>
      </div>
      <div class="hero__trust">
        <span class="trust-pill trust-pill--dark"><svg class="ic"><use href="#i-check"/></svg>Producto nacional patentado</span>
        <span class="trust-pill trust-pill--dark"><svg class="ic"><use href="#i-check"/></svg>3 años de garantía</span>
        <span class="trust-pill trust-pill--dark"><svg class="ic"><use href="#i-check"/></svg>+10 años en Chile</span>
      </div>
    </div>
  </div>
</section>

<style>
/* Hero — full-bleed with before/after slider (legacy 150–185)
   EXCLUDED: .kicker / .kicker--light — global in base.css */
.hero{position:relative;height:720px;overflow:hidden;background:var(--ds-blue-dark)}
@media (max-width:768px){.hero{height:640px}}
.slider{position:absolute;inset:0;cursor:col-resize;overflow:hidden;user-select:none;-webkit-user-select:none}
.slider__layer{position:absolute;inset:0;background-size:cover;background-position:center bottom}
.slider__after{background-color:#6d8a99;background-image:url('/images/rebajes/Rebaje Tina Tradicional.webp')}
.slider__before{background-color:#6d5a48;background-image:url('/images/rebajes/Rebaje Tina Tradicional antes.webp');filter:grayscale(1)}
.slider__label{position:absolute;padding:6px 12px;font-family:var(--ds-sans);font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;border-radius:999px}
.slider__label--after{left:32px;bottom:32px;background:rgba(255,255,255,.92);color:var(--ds-blue-dark)}
@media (max-width:768px){.slider__label--after{left:16px;bottom:90px}}
.slider__handle{position:absolute;top:0;bottom:0;width:2px;background:#fff;box-shadow:0 0 18px rgba(0,0,0,.35);transform:translateX(-1px);pointer-events:none}
.slider__knob{position:absolute;top:50%;width:44px;height:44px;margin-left:-22px;margin-top:-22px;background:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 18px rgba(0,0,0,.3);color:var(--ds-blue);pointer-events:none}
.slider__hint{position:absolute;top:28px;right:32px;padding:8px 14px;background:rgba(255,255,255,.12);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);color:#fff;font-size:12px;font-weight:600;border-radius:999px;border:1px solid rgba(255,255,255,.2);display:flex;align-items:center;gap:6px;pointer-events:none}
@media (max-width:768px){.slider__hint{top:20px;right:20px}}
.hero__overlay{position:absolute;inset:0;background:linear-gradient(135deg,rgba(1,46,77,.55) 0%,rgba(0,114,192,.15) 60%,transparent 100%);pointer-events:none}
.hero__content{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;padding:0 64px 80px;pointer-events:none}
@media (max-width:768px){.hero__content{padding:0 20px 32px}}
.hero__inner{max-width:720px;display:flex;flex-direction:column;gap:24px;pointer-events:auto}
@media (max-width:768px){.hero__inner{gap:16px}}
.h1{margin:0;font-family:var(--ds-display);font-weight:800;font-size:45px;line-height:1.08;letter-spacing:-.03em;color:#fff;text-shadow:0 2px 24px rgba(0,0,0,.3)}
@media (max-width:768px){.h1{font-size:34px}}
.h1 span{display:block}
.hero__sub{margin:0;font-family:var(--ds-sans);font-size:20px;line-height:1.4;color:rgba(255,255,255,.92);max-width:540px}
@media (max-width:768px){.hero__sub{font-size:17px}}
.hero__ctas{display:flex;gap:12px;flex-wrap:wrap;margin-top:4px}
.hero__trust{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px}

.trust-pill{display:inline-flex;align-items:center;gap:8px;padding:8px 14px;font-size:13px;font-weight:500;border-radius:999px}
.trust-pill--light{background:#fff;color:var(--ds-text-strong);border:1px solid var(--ds-border)}
.trust-pill--dark{background:rgba(255,255,255,.12);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);color:#fff;border:1px solid rgba(255,255,255,.2)}
.trust-pill .ic{width:14px;height:14px;stroke-width:2.5;color:var(--ds-blue)}
.trust-pill--dark .ic{color:#fff}
</style>
