---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({ params: { slug: post.id }, props: { post } }));
}

interface Props { post: CollectionEntry<'blog'>; }
const { post } = Astro.props;
const { Content } = await render(post);
---
<BaseLayout title={`${post.data.title} — Ducha Segura®`} description={post.data.excerpt}>
  <article class="section">
    <div class="container" style="max-width:760px">
      <span class="kicker">{post.data.cat} · {post.data.date}</span>
      <h1 class="h2" style="margin-top:10px">{post.data.title}</h1>
      <div class="prose" style="margin-top:24px;font-size:17px;line-height:1.7"><Content /></div>
    </div>
  </article>
</BaseLayout>
