---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Página no encontrada — Ducha Segura®" description="La página que buscas no existe.">
  <section class="section">
    <div class="container" style="text-align:center">
      <h1 class="h2">Página no encontrada</h1>
      <p class="lead" style="margin-left:auto;margin-right:auto">El enlace puede estar roto o la página se movió.</p>
      <a class="btn btn--primary btn--lg" href="/" style="margin-top:24px">Volver al inicio</a>
    </div>
  </section>
</BaseLayout>
