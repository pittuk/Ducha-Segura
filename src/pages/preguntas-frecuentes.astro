---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../data/site';

// ⚠️ BORRADOR de FAQ — revisar/ajustar contenidos con el cliente.
const FAQ: { q: string; a: string }[] = [
  {
    q: '¿Qué es el rebaje de tina?',
    a: 'Es la adaptación de tu tina existente: realizamos un corte en una sección del borde e instalamos una pieza de fibra de vidrio reforzada que crea un acceso bajo y seguro, sin sacar la tina.',
  },
  {
    q: '¿Cuánto demora la instalación?',
    a: 'El proceso completo se realiza en tu domicilio en menos de 2 horas, normalmente el mismo día.',
  },
  {
    q: '¿Genera obras o riesgo de filtraciones?',
    a: 'No. No tocamos las cañerías, por lo que no hay riesgo de filtraciones. Retiramos los residuos y dejamos el área limpia.',
  },
  {
    q: '¿Qué garantía tiene?',
    a: 'Entregamos 3 años de garantía sobre la pieza instalada, siguiendo las reglas de uso y mantención.',
  },
  {
    q: '¿En qué regiones tienen cobertura?',
    a: 'Tenemos despacho e instalación en la Región Metropolitana, Valparaíso y Bío Bío. Para otras regiones, consúltanos por el servicio a tu zona.',
  },
  {
    q: '¿Tienen convenios o descuentos?',
    a: 'Sí. Contamos con convenios con bancos, cajas, municipios y aseguradoras que ofrecen descuentos. Consúltanos qué convenio aplica para ti.',
  },
  {
    q: '¿Puedo comprar solo la pieza para instalarla yo mismo?',
    a: 'Sí. Ofrecemos kits "hágalo usted mismo" que incluyen la pieza de rebaje y un manual de instalación paso a paso.',
  },
  {
    q: '¿Qué tipos de tina pueden adaptar?',
    a: 'Adaptamos tinas tradicionales y de hidromasaje (jacuzzi), entre otros materiales. Si no sabes qué tina tienes, nuestros técnicos la identifican en la visita.',
  },
  {
    q: '¿La pieza es antideslizante?',
    a: 'Sí. La superficie incorpora una textura antideslizante de fábrica para prevenir caídas.',
  },
  {
    q: '¿Cómo cotizo?',
    a: 'Puedes completar tu cotización en línea desde la sección Cotizar o escribirnos directamente por WhatsApp.',
  },
];
---
<BaseLayout title="Preguntas Frecuentes — Ducha Segura®" description="Resolvemos las dudas más comunes sobre el rebaje de tina de Ducha Segura®: instalación, garantía, cobertura, convenios y más.">
  <section class="section">
    <div class="container faq">
      <header class="section-head">
        <span class="kicker">Ayuda</span>
        <h1 class="h2">Preguntas frecuentes</h1>
        <p class="lead">Las dudas más comunes sobre el rebaje de tina. ¿No encuentras la tuya? <a href={SITE.whatsappUrl} target="_blank" rel="noopener">Escríbenos por WhatsApp</a>.</p>
      </header>

      <div class="faq__list">
        {FAQ.map((item) => (
          <details class="faq__item">
            <summary class="faq__q">
              <span>{item.q}</span>
              <svg class="ic faq__chevron"><use href="#i-chevron"/></svg>
            </summary>
            <p class="faq__a">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .faq{max-width:820px}
  .faq__list{display:flex;flex-direction:column;gap:12px;margin-top:32px}
  .faq__item{border:1px solid var(--ds-border);border-radius:var(--ds-radius-lg);background:#fff;overflow:hidden;transition:border-color .15s,box-shadow .15s}
  .faq__item[open]{border-color:var(--ds-blue-soft);box-shadow:var(--ds-shadow)}
  .faq__q{display:flex;align-items:center;justify-content:space-between;gap:16px;cursor:pointer;list-style:none;padding:18px 20px;font-family:var(--ds-display);font-weight:700;font-size:18px;color:var(--ds-text-strong);line-height:1.3}
  .faq__q::-webkit-details-marker{display:none}
  .faq__q:focus-visible{outline:2px solid var(--ds-blue);outline-offset:2px}
  .faq__chevron{width:20px;height:20px;min-width:20px;stroke-width:2.5;color:var(--ds-blue);transition:transform .2s}
  .faq__item[open] .faq__chevron{transform:rotate(180deg)}
  .faq__a{margin:0;padding:0 20px 20px;font-size:15.5px;line-height:1.6;color:var(--ds-text)}
</style>
