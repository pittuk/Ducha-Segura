---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../data/site';

const title = 'Acción Social';
const description = 'Operativos sociales de rebaje de tina y adaptación de baños para personas mayores y con movilidad reducida en situación vulnerable. Suma a tu empresa o fundación.';

const valores = [
  { t: 'Seguridad real', d: 'Adaptamos cada baño para evitar caídas o accidentes graves, reduciendo potenciales hospitalizaciones en la comunidad.' },
  { t: 'Impacto territorial', d: 'Operamos en zonas urbanas, rurales y aisladas de todo Chile, adaptando la logística al foco geográfico de tu organización.' },
  { t: 'Autovalencia', d: 'Devolvemos independencia a personas mayores y con movilidad reducida, mejorando su calidad de vida y la tranquilidad de sus familias.' },
  { t: 'Ecosistema solidario', d: 'Tu organización aporta los recursos, Ducha Segura® ejecuta el proyecto y las comunidades reciben bienestar.' },
];

const faqs = [
  { q: '¿Qué debo hacer para coordinar un proyecto en conjunto?', a: 'Contáctanos por nuestros canales para evaluar las necesidades del grupo o comunidad. Trabajamos junto al encargado de cada organización para planificar fechas, domicilios y servicios. Nos adaptamos tanto a empresas privadas como a municipalidades.' },
  { q: '¿Realizan proyectos sociales en todo Chile?', a: 'Sí. Viajamos a lo largo del país para llevar el servicio directamente al domicilio de quienes lo necesitan. Si tu organización está fuera de la Región Metropolitana, evaluamos cada caso y coordinamos la logística.' },
  { q: '¿Trabajan con fundaciones y organizaciones sin fines de lucro?', a: 'Sí, colaboramos con fundaciones y organizaciones benéficas que buscan mejorar la calidad de vida de personas mayores o en situación de vulnerabilidad. Contáctanos para incluir nuestros servicios en tu iniciativa.' },
  { q: '¿Qué otros servicios ofrecen además del rebaje de tina?', a: 'Instalación de barras de apoyo, adecuación de espacios y otras adaptaciones para mayor autonomía y seguridad en el hogar. Te asesoramos según las necesidades de cada caso.' },
];

const galeria = ['Proposito.webp', 'Proposito-2.webp', 'Proposito-3.webp', 'Proposito-4.webp', 'Proposito-5.webp', '9.webp'];

const storySlugs = [
  'transformando-vidas-ducha-segura-mejora-la-calidad-de-vida-de-jorge-y-su-familia',
  'fortaleciendo-la-autonomia-y-seguridad-nuevas-alianzas-de-ducha-segura',
  'una-sorpresa-que-cambia-vidas-la-iniciativa-de-ducha-segura-que-ilumino-el-hogar-de-edita',
];
const allPosts = await getCollection('blog');
const stories = storySlugs
  .map(s => allPosts.find(p => p.id === s))
  .filter((p): p is (typeof allPosts)[number] => Boolean(p));
---
<BaseLayout title={`${title} — Ducha Segura®`} description={description}>
  <!-- Hero -->
  <section class="section as-hero">
    <div class="container as-hero__grid">
      <div>
        <div class="kicker" style="margin-bottom:12px">Acción social</div>
        <h1 class="h1 as-hero__h1">Juntos por la autonomía de quienes más lo necesitan</h1>
        <p class="lead">Si buscas que tu empresa o fundación deje una huella que transforme vidas, unamos fuerzas. Prevenir caídas y devolver la seguridad en el hogar empieza por el baño.</p>
        <div class="as-ctas">
          <a href="#contacto" class="btn btn--primary btn--lg"><span>Conversemos</span><svg class="ic"><use href="#i-arrow" /></svg></a>
          <a href="#proposito" class="btn btn--ghost-dark btn--lg">Conoce nuestro propósito</a>
        </div>
      </div>
      <img class="as-hero__img" src="/images/paginas/accion-social/Slider.webp" alt="Operativo social de Ducha Segura® en terreno" loading="eager" />
    </div>
  </section>

  <!-- Por qué -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-head"><h2 class="h2">Bañarse no debería ser un acto de riesgo</h2><p class="lead">En Chile, miles de personas conviven a diario con una tina que ya no pueden cruzar. Ducha Segura® existe para derribar esa barrera, comunidad por comunidad, junto a empresas e instituciones comprometidas.</p></div>
      <div class="as-values">
        {valores.map(v => (
          <article class="as-value">
            <div class="as-value__ic"><svg class="ic"><use href="#i-check" /></svg></div>
            <h3 class="as-value__t">{v.t}</h3>
            <p class="as-value__d">{v.d}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Propósito + cita -->
  <section class="section" id="proposito">
    <div class="container as-purpose">
      <div class="as-purpose__media"><img src="/images/paginas/accion-social/Proposito.webp" alt="Operativo de rebaje de tina de Ducha Segura®" loading="lazy" /></div>
      <div class="as-purpose__text">
        <div class="kicker" style="margin-bottom:10px">Nuestro propósito</div>
        <h2 class="h2">Cambiando vidas con el rebaje de tina</h2>
        <blockquote class="as-quote">«No solo adaptamos tinas, transformamos realidades. Queremos acortar las barreras de la desigualdad, convirtiendo baños vulnerables en entornos de dignidad y seguridad. Ponemos la experiencia de nuestro equipo al servicio de devolver la tranquilidad a miles de familias.»</blockquote>
        <p class="as-quote__author">— Javier Orellana, fundador de Ducha Segura®</p>
        <a href="#contacto" class="btn btn--primary">Quiero unirme</a>
      </div>
    </div>
  </section>

  <!-- Galería operativos -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-head"><div class="kicker" style="margin-bottom:8px">En terreno</div><h2 class="h2">Operativos que dejan huella</h2></div>
      <div class="as-gallery">
        {galeria.map((g, i) => (
          <img src={`/images/paginas/accion-social/${g}`} alt={`Operativo social de Ducha Segura® ${i + 1}`} loading="lazy" />
        ))}
      </div>
    </div>
  </section>

  <!-- Historias (blog) -->
  <section class="section">
    <div class="container">
      <div class="section-head"><div class="kicker" style="margin-bottom:8px">Acciones realizadas</div><h2 class="h2">Historias que engrandecen nuestro corazón</h2><p class="lead">Cada relato es un acto de valentía y personas que hoy viven con mayor dignidad.</p></div>
      <div class="blog-grid">
        {stories.map(post => (
          <BlogCard
            slug={post.id}
            cat={post.data.cat}
            date={post.data.date}
            title={post.data.title}
            excerpt={post.data.excerpt}
            label={post.data.label}
            bg={post.data.bg}
            image={post.data.image}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--alt">
    <div class="container" style="max-width:820px">
      <div class="section-head"><h2 class="h2">Lo que las empresas suelen preguntarnos</h2><p class="lead">¿Tienes otra duda? Escríbenos y agendamos una reunión sin compromiso.</p></div>
      <div class="as-faq">
        {faqs.map(f => (
          <details class="as-faq__item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Contacto + formulario -->
  <section class="section" id="contacto">
    <div class="container as-contact">
      <div class="as-contact__info">
        <div class="kicker" style="margin-bottom:10px">Hablemos</div>
        <h2 class="h2">Ayudemos a más personas que lo necesitan</h2>
        <p class="lead">Cuéntanos quién eres y diseñemos acciones con impacto medible para tu organización y para Chile.</p>
        <ul class="as-contact__list">
          <li><svg class="ic"><use href="#i-whatsapp" /></svg><a href={SITE.whatsappUrl} target="_blank" rel="noopener">+56 9 3404 4939</a></li>
          <li><svg class="ic"><use href="#i-phone" /></svg><a href="tel:+56966354714">+56 9 6635 4714</a></li>
          <li><svg class="ic"><use href="#i-info" /></svg><a href="mailto:contacto@duchasegura.cl">contacto@duchasegura.cl</a></li>
        </ul>
      </div>

      <form class="as-form" id="asForm">
        <h3 class="as-form__title">Rellena el formulario</h3>
        <p class="as-form__sub">Te responderemos en menos de 24 horas.</p>
        <div class="as-form__row">
          <input type="text" name="nombre" placeholder="Nombre completo" required />
          <input type="tel" name="telefono" placeholder="Teléfono" required />
        </div>
        <div class="as-form__row">
          <input type="email" name="correo" placeholder="Correo" required />
          <input type="text" name="empresa" placeholder="Empresa / organización" required />
        </div>
        <textarea name="caso" placeholder="Cuéntanos tu interés, recursos disponibles o región de preferencia." rows="4"></textarea>
        <button type="submit" class="btn btn--primary btn--full">
          <svg class="ic"><use href="#i-whatsapp" /></svg><span>Enviar por WhatsApp</span>
        </button>
      </form>
    </div>
  </section>

  <style>
    .as-hero__grid{display:grid;grid-template-columns:1.05fr .95fr;gap:40px;align-items:center}
    @media (max-width:900px){.as-hero__grid{grid-template-columns:1fr;gap:28px}}
    .as-hero__h1{font-size:42px;line-height:1.08;color:var(--ds-text-strong);letter-spacing:-.02em;margin:0 0 16px}
    @media (max-width:768px){.as-hero__h1{font-size:32px}}
    .as-hero__img{width:100%;height:100%;max-height:400px;object-fit:cover;border-radius:var(--ds-radius-lg);box-shadow:var(--ds-shadow-lg)}
    .as-ctas{display:flex;flex-wrap:wrap;gap:12px;margin-top:24px}

    .as-values{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
    @media (max-width:900px){.as-values{grid-template-columns:1fr 1fr}}
    @media (max-width:560px){.as-values{grid-template-columns:1fr}}
    .as-value{background:#fff;border:1px solid var(--ds-border);border-radius:var(--ds-radius-lg);padding:22px;box-shadow:var(--ds-shadow)}
    .as-value__ic{width:40px;height:40px;border-radius:50%;background:var(--ds-blue-soft);color:var(--ds-blue);display:flex;align-items:center;justify-content:center;margin-bottom:14px}
    .as-value__ic .ic{width:20px;height:20px;stroke-width:2.5}
    .as-value__t{margin:0 0 6px;font-family:var(--ds-display);font-weight:700;font-size:17px;color:var(--ds-text-strong)}
    .as-value__d{margin:0;font-size:14px;line-height:1.5;color:var(--ds-text)}

    .as-purpose{display:grid;grid-template-columns:1fr 1.1fr;gap:40px;align-items:center}
    @media (max-width:900px){.as-purpose{grid-template-columns:1fr;gap:24px}}
    .as-purpose__media img{width:100%;border-radius:var(--ds-radius-lg);box-shadow:var(--ds-shadow);display:block}
    .as-quote{margin:18px 0 8px;padding-left:18px;border-left:3px solid var(--ds-blue);font-family:var(--ds-serif,Georgia,serif);font-style:italic;font-size:19px;line-height:1.55;color:var(--ds-text-strong)}
    .as-quote__author{margin:0 0 20px;font-size:14px;font-weight:700;color:var(--ds-text)}

    .as-gallery{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
    @media (max-width:768px){.as-gallery{grid-template-columns:1fr 1fr;gap:10px}}
    .as-gallery img{width:100%;aspect-ratio:4/3;object-fit:cover;border-radius:var(--ds-radius);display:block}

    .as-faq{display:flex;flex-direction:column;gap:10px}
    .as-faq__item{background:#fff;border:1px solid var(--ds-border);border-radius:var(--ds-radius);padding:4px 18px}
    .as-faq__item summary{cursor:pointer;list-style:none;padding:14px 0;font-weight:600;font-size:15px;color:var(--ds-text-strong);display:flex;justify-content:space-between;align-items:center;gap:12px}
    .as-faq__item summary::-webkit-details-marker{display:none}
    .as-faq__item summary::after{content:'+';font-size:22px;color:var(--ds-blue);font-weight:400;line-height:1}
    .as-faq__item[open] summary::after{content:'–'}
    .as-faq__item p{margin:0 0 16px;font-size:14px;line-height:1.6;color:var(--ds-text)}

    .as-contact{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start}
    @media (max-width:900px){.as-contact{grid-template-columns:1fr;gap:28px}}
    .as-contact__list{list-style:none;padding:0;margin:24px 0 0;display:flex;flex-direction:column;gap:14px}
    .as-contact__list li{display:flex;align-items:center;gap:12px;font-size:15px;font-weight:600;color:var(--ds-text-strong)}
    .as-contact__list .ic{width:18px;height:18px;color:var(--ds-blue)}
    .as-contact__list a{color:inherit}
    .as-form{background:#fff;border:1px solid var(--ds-border);border-radius:var(--ds-radius-lg);box-shadow:var(--ds-shadow);padding:28px;display:flex;flex-direction:column;gap:12px}
    .as-form__title{margin:0;font-family:var(--ds-display);font-weight:700;font-size:20px;color:var(--ds-text-strong)}
    .as-form__sub{margin:0 0 6px;font-size:13px;color:var(--ds-text)}
    .as-form__row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    @media (max-width:480px){.as-form__row{grid-template-columns:1fr}}
    .as-form input,.as-form textarea{padding:11px 13px;border:1px solid var(--ds-border);border-radius:var(--ds-radius);font-family:var(--ds-sans);font-size:14px;color:var(--ds-text-strong);background:#fff;outline:none;transition:border-color .15s;width:100%}
    .as-form input:focus,.as-form textarea:focus{border-color:var(--ds-blue)}
    .as-form textarea{resize:vertical;min-height:90px}
    .as-form .btn{margin-top:4px}
  </style>

  <script>
    document.addEventListener('astro:page-load', () => {
      const form = document.getElementById('asForm') as HTMLFormElement | null;
      if (!form || form.dataset.bound) return;
      form.dataset.bound = '1';
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        if (!form.reportValidity()) return;
        const d = new FormData(form);
        const msg = [
          '*Acción Social — Ducha Segura®*',
          '',
          `Nombre: ${d.get('nombre')}`,
          `Teléfono: ${d.get('telefono')}`,
          `Correo: ${d.get('correo')}`,
          `Empresa / organización: ${d.get('empresa')}`,
          d.get('caso') ? `\n${d.get('caso')}` : '',
        ].filter(Boolean).join('\n');
        window.open('https://wa.me/56934044939?text=' + encodeURIComponent(msg), '_blank', 'noopener');
      });
    });
  </script>
</BaseLayout>
