---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductoCard from '../components/ProductoCard.astro';
import { ACCESORIOS } from '../data/productos';
---
<BaseLayout title="Accesorios de seguridad para baño — Ducha Segura®" description="Barras de apoyo, asientos abatibles, antideslizantes y mamparas para baño asistido.">
  <section class="section">
    <div class="container">
      <div class="section-head"><h1 class="h2">Accesorios de seguridad para baño</h1><p class="lead">Complementa tu rebaje con seguridad.</p></div>
      <div class="prod-grid">{ACCESORIOS.map(p => <ProductoCard producto={p} />)}</div>
    </div>
  </section>
</BaseLayout>
