---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryTabs from '../components/CategoryTabs.astro';
import ProductoCard from '../components/ProductoCard.astro';
import { REBAJES, KITS, ACCESORIOS } from '../data/productos';
---
<BaseLayout title="Catálogo — Ducha Segura®" description="Catálogo completo de rebajes de tina y accesorios de seguridad para baño.">
  <section class="section">
    <div class="container">
      <div class="section-head"><h1 class="h2">Catálogo</h1><p class="lead">Rebajes y accesorios para un baño accesible.</p></div>
      <CategoryTabs categories={[{id:'rebajes',label:'Rebajes'},{id:'accesorios',label:'Accesorios'},{id:'kits',label:'Kits'}]} />
      <div class="product-grid">
        {REBAJES.map(p => <div data-cat-item="rebajes"><ProductoCard producto={p} /></div>)}
      </div>
      <div class="prod-grid prod-grid--uniform" style="margin-top:32px">
        {KITS.map(p => <div data-cat-item="kits"><ProductoCard producto={p} /></div>)}
        {ACCESORIOS.map(p => <div data-cat-item="accesorios"><ProductoCard producto={p} /></div>)}
      </div>
    </div>
  </section>
  <script>
    import { initCatalogFilter } from '../scripts/catalog-filter';
    document.addEventListener('astro:page-load', initCatalogFilter);
  </script>

  <style>
    /* Catálogo: kits + accesorios en una sola grilla, TODAS las tarjetas con la misma altura.
       - display:contents hace que el wrapper del filtro "desaparezca" del layout, así la .prod-card
         es el ítem del grid directamente (igual que en /accesorios y /kits, donde funciona).
       - grid-auto-rows:1fr iguala el alto de TODAS las filas a la más alta. */
    .prod-grid--uniform{grid-auto-rows:1fr}
    .prod-grid--uniform > [data-cat-item]{display:contents}
    .prod-grid--uniform > [data-cat-item][hidden]{display:none}

    /* Colapsa una grilla cuando el filtro dejó todos sus ítems ocultos (evita huecos). */
    .product-grid:not(:has([data-cat-item]:not([hidden]))),
    .prod-grid:not(:has([data-cat-item]:not([hidden]))){display:none}
  </style>
</BaseLayout>
