---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ConveniosMarquee from '../components/ConveniosMarquee.astro';
import ComoFunciona from '../components/ComoFunciona.astro';
import CanalesMayoristas from '../components/CanalesMayoristas.astro';
import ProductosTeaser from '../components/ProductosTeaser.astro';
import InstalacionVideo from '../components/InstalacionVideo.astro';
import Calculator from '../components/Calculator.astro';
import Diferenciadores from '../components/Diferenciadores.astro';
import Prensa from '../components/Prensa.astro';
import TestimoniosVideo from '../components/TestimoniosVideo.astro';
import Testimonios from '../components/Testimonios.astro';
import BlogTeaser from '../components/BlogTeaser.astro';
---
<BaseLayout
  title="Ducha Segura® — Rebajes de tina para acceso seguro · Chile"
  description="Rebaje de tina para un baño accesible y seguro para adultos mayores y movilidad reducida. Producto nacional patentado, instalación a domicilio en menos de 2 horas y garantía de 3 años. Cobertura en RM, Valparaíso y Bío Bío."
>
  <Hero />
  <ConveniosMarquee />
  <ComoFunciona />
  <ProductosTeaser />
  <CanalesMayoristas />
  <Calculator />
  <InstalacionVideo />
  <Diferenciadores />
  <TestimoniosVideo />
  <Testimonios />
  <BlogTeaser />
  <Prensa />
</BaseLayout>
